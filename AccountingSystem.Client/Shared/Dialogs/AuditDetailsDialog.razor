@using AccountingSystem.Shared.DTOs
@using MudBlazor

<MudDialog Class="shadcn-dialog">
    <TitleContent>
        <div class="d-flex align-center px-6 pt-6 pb-4">
            <MudIcon Icon="@Icons.Material.Outlined.History" Class="mr-2 text-muted" Size="Size.Small" />
            <h3 style="font-size: 1.25rem; font-weight: 600; letter-spacing: -0.025em; color: var(--text-main); margin: 0;">
                Audit Log Details
            </h3>
        </div>
    </TitleContent>

    <DialogContent>
        <div class="px-6 pb-2">
            <div class="pa-4 mb-6" style="background-color: var(--bg-muted); border-radius: var(--radius-md); border: 1px solid var(--border-color);">
                <MudGrid Spacing="3">
                    <MudItem xs="12" sm="6">
                        <div style="font-size: 0.75rem; color: var(--text-muted); margin-bottom: 0.25rem;">User</div>
                        <div class="d-flex align-center" style="font-size: 0.875rem; font-weight: 500; color: var(--text-main);">
                            <MudIcon Icon="@Icons.Material.Outlined.Person" Size="Size.Small" Class="mr-2 text-muted" />
                            @Log.UserEmail
                        </div>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <div style="font-size: 0.75rem; color: var(--text-muted); margin-bottom: 0.25rem;">Timestamp</div>
                        <div class="d-flex align-center" style="font-size: 0.875rem; font-weight: 500; color: var(--text-main);">
                            <MudIcon Icon="@Icons.Material.Outlined.AccessTime" Size="Size.Small" Class="mr-2 text-muted" />
                            @Log.Timestamp.ToLocalTime().ToString("MMM dd, yyyy HH:mm:ss")
                        </div>
                    </MudItem>
                    <MudItem xs="12" sm="12">
                        <div style="font-size: 0.75rem; color: var(--text-muted); margin-bottom: 0.25rem;">Action</div>
                        <div class="mt-1">
                            <span class="shadcn-badge @GetActionBadgeClass(Log.Action)">
                                <MudIcon Icon="@GetActionIcon(Log.Action)" Size="Size.Small" Class="mr-1" Style="font-size: 14px;" />
                                @Log.Action
                            </span>
                        </div>
                    </MudItem>
                </MudGrid>
            </div>

            <div style="font-size: 0.875rem; font-weight: 600; color: var(--text-main); margin-bottom: 0.5rem; display: flex; align-items: center;">
                <MudIcon Icon="@Icons.Material.Outlined.Code" Size="Size.Small" Class="mr-2 text-muted" />
                Request Payload / Changes
            </div>
            <div class="pa-4" style="max-height: 400px; overflow: auto; background-color: #0f172a; border-radius: var(--radius-md); border: 1px solid var(--border-color);">
                <pre style="font-family: 'ui-monospace', 'SFMono-Regular', 'Menlo', 'Monaco', monospace; font-size: 0.85rem; white-space: pre-wrap; color: #e2e8f0; margin: 0;">@FormatJson(Log.Changes)</pre>
            </div>
        </div>
    </DialogContent>

    <DialogActions>
        <div class="d-flex w-100 justify-end px-6 py-4 mt-2">
            <MudButton OnClick="Cancel"
                       Variant="Variant.Outlined"
                       Class="shadcn-btn-outline"
                       Size="Size.Small">
                Close
            </MudButton>
        </div>
    </DialogActions>
</MudDialog>

<style>
    /* Clean up the default MudBlazor dialog padding so we can style the header/footer */
    .shadcn-dialog .mud-dialog-title {
        padding: 0;
    }

    .shadcn-dialog .mud-dialog-content {
        padding: 0;
    }

    .shadcn-dialog .mud-dialog-actions {
        padding: 0;
    }
</style>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public AuditLogDTO Log { get; set; } = default!;

    private void Cancel() => MudDialog.Cancel();

    private string GetActionBadgeClass(string action)
    {
        if (action == "LOGIN") return "badge-slate";

        if (action.StartsWith("USER-")) return "badge-purple";
        if (action.StartsWith("CUSTOMER-")) return "badge-blue";
        if (action.StartsWith("VENDOR-")) return "badge-orange";
        if (action.StartsWith("ACCOUNT-")) return "badge-green";
        if (action.StartsWith("BILL-")) return "badge-red";
        if (action.StartsWith("INVOICE-")) return "badge-indigo";
        if (action == "JOURNAL-ENTRY") return "badge-slate";

        // Fallbacks for raw HTTP methods
        return action switch
        {
            "POST" => "badge-green",
            "PUT" => "badge-orange",
            "DELETE" => "badge-red",
            _ => "badge-slate"
        };
    }

    private string GetActionIcon(string action)
    {
        if (action == "LOGIN") return Icons.Material.Outlined.Login;

        if (action.StartsWith("USER-")) return Icons.Material.Outlined.Person;
        if (action.StartsWith("CUSTOMER-")) return Icons.Material.Outlined.Person;
        if (action.StartsWith("VENDOR-")) return Icons.Material.Outlined.Business;
        if (action.StartsWith("ACCOUNT-")) return Icons.Material.Outlined.AccountBalance;
        if (action.StartsWith("BILL-")) return Icons.Material.Outlined.Receipt;
        if (action.StartsWith("INVOICE-")) return Icons.Material.Outlined.Receipt;
        if (action == "JOURNAL-ENTRY") return Icons.Material.Outlined.Book;

        // Fallbacks for raw HTTP methods
        return action switch
        {
            "POST" => Icons.Material.Outlined.Add,
            "PUT" => Icons.Material.Outlined.Edit,
            "DELETE" => Icons.Material.Outlined.Delete,
            _ => Icons.Material.Outlined.Circle
        };
    }

    private string FormatJson(string json)
    {
        if (string.IsNullOrEmpty(json)) return "No content";

        try
        {
            var parsed = System.Text.Json.JsonDocument.Parse(json);
            return System.Text.Json.JsonSerializer.Serialize(
                parsed,
                new System.Text.Json.JsonSerializerOptions
                {
                    WriteIndented = true
                });
        }
        catch
        {
            return json;
        }
    }
}