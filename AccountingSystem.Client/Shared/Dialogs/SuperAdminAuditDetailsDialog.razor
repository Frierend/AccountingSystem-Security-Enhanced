@using AccountingSystem.Client.Services
@using AccountingSystem.Shared.DTOs
@using MudBlazor

<MudDialog Class="shadcn-dialog">
    <TitleContent>
        <div class="d-flex align-center px-6 pt-6 pb-4">
            <MudIcon Icon="@Icons.Material.Outlined.AdminPanelSettings" Class="mr-2 text-muted" Size="Size.Small" />
            <h3 style="font-size: 1.25rem; font-weight: 600; color: var(--text-main); margin: 0;">
                SuperAdmin Audit Details
            </h3>
        </div>
    </TitleContent>

    <DialogContent>
        <div class="px-6 pb-2">
            <div class="pa-4 mb-6" style="background-color: var(--bg-muted); border-radius: var(--radius-md); border: 1px solid var(--border-color);">
                <MudGrid Spacing="3">
                    <MudItem xs="12" sm="6">
                        <div style="font-size: 0.75rem; color: var(--text-muted); margin-bottom: 0.25rem;">Admin</div>
                        <div class="d-flex align-center" style="font-size: 0.875rem; font-weight: 500; color: var(--text-main);">
                            <MudIcon Icon="@Icons.Material.Outlined.Security" Size="Size.Small" Class="mr-2 text-muted" />
                            @Log.AdminEmail
                        </div>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <div style="font-size: 0.75rem; color: var(--text-muted); margin-bottom: 0.25rem;">Timestamp</div>
                        <div class="d-flex align-center" style="font-size: 0.875rem; font-weight: 500; color: var(--text-main);">
                            <MudIcon Icon="@Icons.Material.Outlined.AccessTime" Size="Size.Small" Class="mr-2 text-muted" />
                            @AuditTimestampFormatter.FormatLocalDateTime(Log.Timestamp)
                        </div>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <div style="font-size: 0.75rem; color: var(--text-muted); margin-bottom: 0.25rem;">Action</div>
                        <div class="mt-1">
                            <span class="shadcn-badge @GetActionBadgeClass(Log.Action)">@Log.Action</span>
                        </div>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <div style="font-size: 0.75rem; color: var(--text-muted); margin-bottom: 0.25rem;">Target</div>
                        <div style="font-size: 0.875rem; font-weight: 500; color: var(--text-main);">
                            @Log.TargetType: @Log.TargetName
                        </div>
                    </MudItem>
                </MudGrid>
            </div>

            <div style="font-size: 0.875rem; font-weight: 600; color: var(--text-main); margin-bottom: 0.5rem; display: flex; align-items: center;">
                <MudIcon Icon="@Icons.Material.Outlined.CompareArrows" Size="Size.Small" Class="mr-2 text-muted" />
                Change
            </div>
            <div class="pa-4 mb-5" style="background-color: var(--bg-muted); border-radius: var(--radius-md); border: 1px solid var(--border-color);">
                @GetChangeSummary(Log)
            </div>

            <div style="font-size: 0.875rem; font-weight: 600; color: var(--text-main); margin-bottom: 0.5rem; display: flex; align-items: center;">
                <MudIcon Icon="@Icons.Material.Outlined.Info" Size="Size.Small" Class="mr-2 text-muted" />
                Details
            </div>
            <div class="pa-4" style="max-height: 320px; overflow: auto; background-color: #0f172a; border-radius: var(--radius-md); border: 1px solid var(--border-color);">
                <pre style="font-family: 'ui-monospace', 'SFMono-Regular', 'Menlo', 'Monaco', monospace; font-size: 0.85rem; white-space: pre-wrap; color: #e2e8f0; margin: 0;">@GetSafeDetails(Log.Details)</pre>
            </div>
        </div>
    </DialogContent>

    <DialogActions>
        <div class="d-flex w-100 justify-end px-6 py-4 mt-2">
            <MudButton OnClick="Cancel"
                       Variant="Variant.Outlined"
                       Class="shadcn-btn-outline"
                       Size="Size.Small">
                Close
            </MudButton>
        </div>
    </DialogActions>
</MudDialog>

<style>
    .shadcn-dialog .mud-dialog-title {
        padding: 0;
    }

    .shadcn-dialog .mud-dialog-content {
        padding: 0;
    }

    .shadcn-dialog .mud-dialog-actions {
        padding: 0;
    }
</style>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public SuperAdminAuditLogDTO Log { get; set; } = default!;

    private void Cancel() => MudDialog.Cancel();

    private static string GetChangeSummary(SuperAdminAuditLogDTO log)
    {
        if (!string.IsNullOrWhiteSpace(log.OldValue) || !string.IsNullOrWhiteSpace(log.NewValue))
        {
            return $"{BlankIfMissing(log.OldValue)} -> {BlankIfMissing(log.NewValue)}";
        }

        return "No before/after status change recorded.";
    }

    private static string GetSafeDetails(string details)
    {
        if (string.IsNullOrWhiteSpace(details))
        {
            return "No additional details.";
        }

        var sensitiveMarkers = new[] { "password=", "otp=", "token=", "secret=", "recoverycode=", "captcha=" };
        return sensitiveMarkers.Any(marker => details.Contains(marker, StringComparison.OrdinalIgnoreCase))
            ? "[Sensitive detail hidden]"
            : details;
    }

    private static string BlankIfMissing(string value) =>
        string.IsNullOrWhiteSpace(value) ? "N/A" : value;

    private static string GetActionBadgeClass(string action)
    {
        if (action.StartsWith("SUPERADMIN-AUTH", StringComparison.OrdinalIgnoreCase)) return "badge-red";
        if (action.StartsWith("SUPERADMIN-", StringComparison.OrdinalIgnoreCase)) return "badge-indigo";
        if (action.Contains("COMPANY", StringComparison.OrdinalIgnoreCase)) return "badge-blue";
        if (action.Contains("USER", StringComparison.OrdinalIgnoreCase)) return "badge-purple";
        return "badge-slate";
    }
}
