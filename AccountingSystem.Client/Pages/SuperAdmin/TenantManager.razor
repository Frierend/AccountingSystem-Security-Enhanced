@page "/superadmin/tenants"
@using AccountingSystem.Shared.DTOs
@using AccountingSystem.Client.Services
@using AccountingSystem.Client.Shared.Dialogs
@using MudBlazor
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "SuperAdmin")]
@inject SuperAdminService SuperAdminService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ILogger<TenantManager> Logger

<PageTitle>Tenant Management - AccSys</PageTitle>

<style>
    /* Premium KPI Cards */
    .sa-metric-card {
        padding: 1.5rem;
        background: var(--bg-surface);
        border-radius: var(--radius-lg);
        border: 1px solid var(--border-color);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        transition: all 0.2s ease;
        box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
        height: 100%;
    }

    .sa-metric-card:hover {
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -2px rgba(0, 0, 0, 0.05);
        border-color: #cbd5e1; /* Slate-300 */
        transform: translateY(-2px);
    }

    .sa-metric-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 1rem;
    }

    .sa-metric-label {
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--text-muted);
        letter-spacing: -0.025em;
    }

    .sa-metric-icon-wrapper {
        width: 36px;
        height: 36px;
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: var(--bg-muted);
    }

    .sa-metric-value {
        font-size: 2rem;
        font-weight: 700;
        color: var(--text-main);
        line-height: 1;
        letter-spacing: -0.05em;
    }

    /* Responsive Filters & Tweaks */
    .table-toolbar-wrapper {
        display: flex;
        flex-direction: row;
        justify-content: space-between;
        align-items: center;
        width: 100%;
        gap: 1rem;
    }

    .table-toolbar-actions {
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 0.75rem;
    }

    .filter-search {
        width: 100%;
        max-width: 250px;
    }

    .filter-status {
        width: 100%;
        max-width: 150px;
    }

    .shadcn-table .mud-table-toolbar {
        height: auto !important;
        padding-top: 1rem !important;
        padding-bottom: 1rem !important;
    }

    /* Mobile Overrides */
    @@media (max-width: 599px) {
        .sa-metric-value {
            font-size: 1.5rem; /* Scale down big numbers for 2x2 grid */
        }

        .sa-metric-card {
            padding: 1rem; /* Less padding to maximize space */
        }

        .table-toolbar-wrapper {
            flex-direction: column;
            align-items: flex-start;
        }

        .table-toolbar-actions {
            flex-direction: column;
            width: 100%;
            align-items: stretch; /* Make inputs fill the container */
        }

        .filter-search, .filter-status {
            max-width: 100%;
        }
    }
</style>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6 mb-10">
    <div class="d-flex flex-column flex-sm-row justify-space-between align-start align-sm-center mb-8 gap-3">
        <div>
            <h2 style="font-size: 1.75rem; font-weight: 700; letter-spacing: -0.025em; color: var(--text-main); margin: 0;">
                Tenant Management
            </h2>
            <p style="color: var(--text-muted); font-size: 0.875rem; margin: 0.25rem 0 0 0;">
                Manage all registered companies in the system.
            </p>
        </div>
        <MudButton Variant="Variant.Outlined"
                   Class="shadcn-btn-outline"
                   StartIcon="@Icons.Material.Outlined.Refresh"
                   Size="Size.Small" 
                   OnClick="LoadData"
                   Disabled="isLoading">
            Refresh Data
        </MudButton>
    </div>

    @if (isLoading)
    {
        <MudGrid Spacing="4" Class="mb-6">
            @for (int i = 0; i < 4; i++)
            {
                <MudItem xs="6" md="3">
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="100%" Height="120px" Style="border-radius: 8px;" />
                </MudItem>
            }
        </MudGrid>
        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="100%" Height="400px" Style="border-radius: 8px;" />
    }
    else
    {
        <MudGrid Spacing="4" Class="mb-6">
            <MudItem xs="6" md="3">
                <div class="sa-metric-card">
                    <div class="sa-metric-header">
                        <div class="sa-metric-label">Total Tenants</div>
                        <div class="sa-metric-icon-wrapper">
                            <MudIcon Icon="@Icons.Material.Outlined.Business" Size="Size.Small" Style="color: #3b82f6;" /> 
                        </div>
                    </div>
                    <div class="sa-metric-value">@tenants.Count</div>
                </div>
            </MudItem>
            <MudItem xs="6" md="3">
                <div class="sa-metric-card">
                    <div class="sa-metric-header">
                        <div class="sa-metric-label">Active</div>
                        <div class="sa-metric-icon-wrapper" style="background-color: #d1fae5;">
                            <MudIcon Icon="@Icons.Material.Outlined.CheckCircleOutline" Size="Size.Small" Style="color: #10b981;" /> 
                        </div>
                    </div>
                    <div class="sa-metric-value">@tenants.Count(t => t.Status == "Active")</div>
                </div>
            </MudItem>
            <MudItem xs="6" md="3">
                <div class="sa-metric-card">
                    <div class="sa-metric-header">
                        <div class="sa-metric-label">Suspended</div>
                        <div class="sa-metric-icon-wrapper" style="background-color: #fef3c7;">
                            <MudIcon Icon="@Icons.Material.Outlined.PauseCircleOutline" Size="Size.Small" Style="color: #f59e0b;" /> 
                        </div>
                    </div>
                    <div class="sa-metric-value">@tenants.Count(t => t.Status == "Suspended")</div>
                </div>
            </MudItem>
            <MudItem xs="6" md="3">
                <div class="sa-metric-card">
                    <div class="sa-metric-header">
                        <div class="sa-metric-label">Blocked</div>
                        <div class="sa-metric-icon-wrapper" style="background-color: #fef2f2;">
                            <MudIcon Icon="@Icons.Material.Outlined.Block" Size="Size.Small" Style="color: #ef4444;" /> 
                        </div>
                    </div>
                    <div class="sa-metric-value">@tenants.Count(t => t.Status == "Blocked")</div>
                </div>
            </MudItem>
        </MudGrid>

        <MudCard Elevation="0" Outlined="true" Class="shadcn-card">
            <MudTable Items="@tenants" Hover="true" Loading="@isLoading" Filter="new Func<TenantDTO, bool>(FilterFunc)"
                      Dense="false" Elevation="0" Class="shadcn-table" Breakpoint="Breakpoint.Sm">
                <ToolBarContent>
                    <div class="table-toolbar-wrapper">
                        <div style="font-size: 1.125rem; font-weight: 600; color: var(--text-main); letter-spacing: -0.025em;">
                            Registered Companies
                        </div>
                        <div class="table-toolbar-actions">
                            <MudTextField @bind-Value="searchString" 
                                          Placeholder="Search tenants..." 
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Outlined.Search" 
                                          IconSize="Size.Small" 
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="shadcn-input bg-surface m-0 filter-search" />
                                          
                            <MudSelect T="string" 
                                       @bind-Value="statusFilter" 
                                       Variant="Variant.Outlined" 
                                       Margin="Margin.Dense"
                                       Class="shadcn-input bg-surface m-0 filter-status">
                                <MudSelectItem T="string" Value='@("All")'>All Statuses</MudSelectItem>
                                <MudSelectItem T="string" Value='@("Active")'>Active</MudSelectItem>
                                <MudSelectItem T="string" Value='@("Suspended")'>Suspended</MudSelectItem>
                                <MudSelectItem T="string" Value='@("Blocked")'>Blocked</MudSelectItem>
                            </MudSelect>
                        </div>
                    </div>
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>Company Name</MudTh>
                    <MudTh>Address</MudTh>
                    <MudTh>Registered</MudTh>
                    <MudTh>Users</MudTh>
                    <MudTh>Last Activity</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh Style="text-align: right;">Actions</MudTh>
                </HeaderContent>
                <RowTemplate Context="context">
                    <MudTd DataLabel="Name">
                        <div style="font-weight: 500; color: var(--text-main);">@context.Name</div>
                    </MudTd>
                    <MudTd DataLabel="Address">
                        <div style="color: var(--text-muted); font-size: 0.875rem;">@(context.Address ?? "—")</div>
                    </MudTd>
                    <MudTd DataLabel="Registered" Style="white-space: nowrap;">
                        <div style="color: var(--text-muted); font-size: 0.875rem;">@context.CreatedAt.ToString("MMM dd, yyyy")</div>
                    </MudTd>
                    <MudTd DataLabel="Users">
                        <span class="shadcn-badge badge-slate" style="font-size: 0.7rem;">@context.UserCount users</span>
                    </MudTd>
                    <MudTd DataLabel="Last Activity" Style="white-space: nowrap;">
                        <div style="color: var(--text-muted); font-size: 0.875rem;">
                            @(context.LastActivityDate?.ToString("MMM dd, yyyy") ?? "No activity")
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Status">
                        @switch (context.Status)
                        {
                            case "Active":
                                <span class="shadcn-badge badge-green">Active</span>
                                break;
                            case "Suspended":
                                <span class="shadcn-badge badge-orange">Suspended</span>
                                break;
                            case "Blocked":
                                <span class="shadcn-badge badge-red">Blocked</span>
                                break;
                            default:
                                <span class="shadcn-badge badge-slate">@context.Status</span>
                                break;
                        }
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <MudMenu Icon="@Icons.Material.Outlined.MoreVert" Dense="true" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                            @if (context.Status != "Active")
                            {
                                <MudMenuItem Icon="@Icons.Material.Outlined.CheckCircleOutline"
                                             OnClick="@(() => ConfirmActivate(context))">
                                    Activate
                                </MudMenuItem>
                            }
                            @if (context.Status != "Suspended")
                            {
                                <MudMenuItem Icon="@Icons.Material.Outlined.PauseCircleOutline"
                                             OnClick="@(() => ConfirmSuspend(context))">
                                    Suspend
                                </MudMenuItem>
                            }
                            @if (context.Status != "Blocked")
                            {
                                <MudMenuItem Icon="@Icons.Material.Outlined.Block" 
                                             Style="color: var(--color-destructive);"
                                             OnClick="@(() => ConfirmBlock(context))">
                                    Block
                                </MudMenuItem>
                            }
                        </MudMenu>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudCard>
    }
</MudContainer>

@code {
    private List<TenantDTO> tenants = new List<TenantDTO>();
    private bool isLoading = true;
    private string searchString = "";
    private string statusFilter = "All";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            tenants = await SuperAdminService.GetAllCompaniesAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load tenants.");
            Snackbar.Add("Failed to load tenants. Please try again.", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ChangeStatus(TenantDTO tenant, string newStatus)
    {
        try
        {
            await SuperAdminService.UpdateCompanyStatusAsync(tenant.Id, newStatus);
            tenant.Status = newStatus;
            tenant.IsActive = newStatus == "Active";
            Snackbar.Add($"'{tenant.Name}' is now {newStatus}.", Severity.Success);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to update tenant status for tenant id {TenantId}.", tenant.Id);
            Snackbar.Add("Unable to update tenant status. Please try again.", Severity.Error);
            await LoadData();
        }
    }

    private async Task ConfirmActivate(TenantDTO tenant)
    {
        var result = await ShowConfirmDialog(
            $"Activate company '{tenant.Name}'?",
            "Users from this company will be granted full access to the system.",
            "Activate",
            Color.Success);

        if (result)
        {
            await ChangeStatus(tenant, "Active");
        }
    }

    private async Task ConfirmSuspend(TenantDTO tenant)
    {
        var result = await ShowConfirmDialog(
            $"Suspend company '{tenant.Name}'?",
            "Users from this company will be temporarily restricted from accessing the system.",
            "Suspend",
            Color.Warning);

        if (result)
        {
            await ChangeStatus(tenant, "Suspended");
        }
    }

    private async Task ConfirmBlock(TenantDTO tenant)
    {
        var result = await ShowConfirmDialog(
            $"Block company '{tenant.Name}'?",
            "All users from this company will be prevented from accessing the system until unblocked.",
            "Block",
            Color.Error);

        if (result)
        {
            await ChangeStatus(tenant, "Blocked");
        }
    }

    private async Task<bool> ShowConfirmDialog(string content, string subText, string buttonText, Color color)
    {
        var parameters = new DialogParameters
        {
            [nameof(ShadcnConfirmDialog.ContentText)] = content,
            [nameof(ShadcnConfirmDialog.SubText)] = subText,
            [nameof(ShadcnConfirmDialog.ButtonText)] = buttonText,
            [nameof(ShadcnConfirmDialog.Color)] = color
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ShadcnConfirmDialog>("Confirm", parameters, options);
        var dialogResult = await dialog.Result;
        return dialogResult is not null && !dialogResult.Canceled;
    }

    private bool FilterFunc(TenantDTO element)
    {
        bool matchesSearch = string.IsNullOrWhiteSpace(searchString) ||
            (element.Name?.Contains(searchString, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (element.Address?.Contains(searchString, StringComparison.OrdinalIgnoreCase) ?? false);

        bool matchesStatus = statusFilter == "All" || element.Status == statusFilter;

        return matchesSearch && matchesStatus;
    }
}
