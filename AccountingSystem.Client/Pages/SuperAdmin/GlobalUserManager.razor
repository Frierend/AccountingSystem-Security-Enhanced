@page "/superadmin/users"
@using AccountingSystem.Shared.DTOs
@using AccountingSystem.Shared.Validation
@using AccountingSystem.Client.Services
@using AccountingSystem.Client.Shared.Dialogs
@using MudBlazor
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "SuperAdmin")]
@inject SuperAdminService SuperAdminService
@inject AuthService AuthService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ILogger<GlobalUserManager> Logger

<PageTitle>Global User Management - AccSys</PageTitle>

<style>
    /* 5-Column Responsive Grid for Stats */
    .sa-stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 1.5rem;
        margin-bottom: 1.5rem;
    }

    /* Premium KPI Cards */
    .sa-metric-card {
        padding: 1.5rem;
        background: var(--bg-surface);
        border-radius: var(--radius-lg);
        border: 1px solid var(--border-color);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        transition: all 0.2s ease;
        box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
        height: 100%;
    }

    .sa-metric-card:hover {
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -2px rgba(0, 0, 0, 0.05);
        border-color: #cbd5e1;
        transform: translateY(-2px);
    }

    .sa-metric-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 1rem;
    }

    .sa-metric-label {
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--text-muted);
        letter-spacing: -0.025em;
    }

    .sa-metric-icon-wrapper {
        width: 36px;
        height: 36px;
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: var(--bg-muted);
    }

    .sa-metric-value {
        font-size: 2rem;
        font-weight: 700;
        color: var(--text-main);
        line-height: 1;
        letter-spacing: -0.05em;
    }

    /* ─── Toolbar ─────────────────────────────────────────────── */
    .shadcn-table .mud-table-toolbar {
        height: auto !important;
        padding: 1rem !important;
    }

    .table-toolbar-wrapper {
        display: flex;
        flex-direction: row;
        justify-content: space-between;
        align-items: center;
        width: 100%;
        gap: 1rem;
        flex-wrap: nowrap;
    }

    .table-toolbar-title {
        font-size: 1.125rem;
        font-weight: 600;
        color: var(--text-main);
        letter-spacing: -0.025em;
        white-space: nowrap;
        flex-shrink: 0;
    }

    .table-toolbar-actions {
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: nowrap;
    }

    /* Neutralise every MudBlazor internal margin/padding that
       pushes form controls out of vertical alignment */
    .table-toolbar-actions .mud-input-control,
    .table-toolbar-actions .mud-input-control > .mud-input-control-input-shrink,
    .table-toolbar-actions .mud-form-control,
    .table-toolbar-actions .mud-select,
    .table-toolbar-actions .mud-text-field {
        margin: 0 !important;
        padding: 0 !important;
    }

    /* Inner helper text / label rows can add invisible height — kill them */
    .table-toolbar-actions .mud-input-helper-text,
    .table-toolbar-actions .mud-input-label {
        display: none !important;
    }

    /* Fixed widths so everything sits flush on one line */
    .filter-search {
        width: 240px;
        min-width: 0;
    }

    .filter-dropdown {
        width: 140px;
        min-width: 0;
    }

    /* ─── Mobile ──────────────────────────────────────────────── */
    @@media (max-width: 599px) {
        .sa-stats-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 1rem;
        }

        .sa-metric-value {
            font-size: 1.5rem;
        }

        .sa-metric-card {
            padding: 1rem;
        }

        .table-toolbar-wrapper {
            flex-direction: column;
            align-items: flex-start;
            flex-wrap: wrap;
        }

        .table-toolbar-actions {
            flex-direction: column;
            width: 100%;
            align-items: stretch;
            flex-wrap: wrap;
        }

        .filter-search,
        .filter-dropdown {
            width: 100%;
        }
    }
</style>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6 mb-10">
    <div class="d-flex flex-column flex-sm-row justify-space-between align-start align-sm-center mb-8 gap-3">
        <div>
            <h2 style="font-size: 1.75rem; font-weight: 700; letter-spacing: -0.025em; color: var(--text-main); margin: 0;">
                Global User Directory
            </h2>
            <p style="color: var(--text-muted); font-size: 0.875rem; margin: 0.25rem 0 0 0;">
                Manage all users across all tenant companies.
            </p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Outlined.AdminPanelSettings"
                       Size="Size.Small"
                       OnClick="ToggleCreateSuperAdmin"
                       Disabled="isLoading">
                Add Backup SuperAdmin
            </MudButton>
            <MudButton Variant="Variant.Outlined"
                       Class="shadcn-btn-outline"
                       StartIcon="@Icons.Material.Outlined.Refresh"
                       Size="Size.Small"
                       OnClick="LoadData"
                       Disabled="isLoading">
                Refresh Data
            </MudButton>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="sa-stats-grid">
            @for (int i = 0; i < 4; i++)
            {
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="100%" Height="120px" Style="border-radius: 8px;" />
            }
        </div>
        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="100%" Height="400px" Style="border-radius: 8px;" />
    }
    else
    {
        <MudCard Elevation="0" Outlined="true" Class="shadcn-card mb-6">
            <MudCardContent Class="pa-4">
                <div class="d-flex flex-column flex-sm-row justify-space-between align-start align-sm-center gap-3 mb-4">
                    <div>
                        <div style="font-size: 1.125rem; font-weight: 600; color: var(--text-main);">System Administrators</div>
                        <div style="font-size: 0.875rem; color: var(--text-muted);">Maintain at least one backup SuperAdmin for account recovery and governance continuity.</div>
                    </div>
                    <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined">
                        Active: @superAdmins.Count(admin => admin.Status == "Active" && admin.IsActive)
                    </MudChip>
                </div>

                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
                    New SuperAdmins must confirm email before using Email OTP MFA. Authenticator App MFA and Email OTP MFA can be enabled independently from the profile.
                </MudAlert>

                @if (showCreateSuperAdmin)
                {
                    <MudPaper Outlined="true" Class="pa-4 mb-4" Style="background: var(--bg-background);">
                        <EditForm Model="@createSuperAdminModel" OnValidSubmit="HandleCreateSuperAdminAsync">
                            <DataAnnotationsValidator />
                            <MudGrid Spacing="3">
                                <MudItem xs="12" md="3">
                                    <MudTextField Label="Full name"
                                                  @bind-Value="createSuperAdminModel.FullName"
                                                  For="@(() => createSuperAdminModel.FullName)"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  Class="shadcn-input" />
                                </MudItem>
                                <MudItem xs="12" md="3">
                                    <MudTextField Label="Email"
                                                  @bind-Value="createSuperAdminModel.Email"
                                                  For="@(() => createSuperAdminModel.Email)"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  Class="shadcn-input" />
                                </MudItem>
                                <MudItem xs="12" md="3">
                                    <MudTextField Label="Temporary password"
                                                  @bind-Value="createSuperAdminModel.Password"
                                                  For="@(() => createSuperAdminModel.Password)"
                                                  InputType="InputType.Password"
                                                  HelperText="@PasswordPolicy.Description"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  Class="shadcn-input" />
                                </MudItem>
                                <MudItem xs="12" md="3">
                                    <MudTextField Label="Confirm password"
                                                  @bind-Value="createSuperAdminModel.ConfirmPassword"
                                                  For="@(() => createSuperAdminModel.ConfirmPassword)"
                                                  InputType="InputType.Password"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  Class="shadcn-input" />
                                </MudItem>
                            </MudGrid>

                            <div class="d-flex flex-wrap gap-3 justify-end mt-4">
                                <MudButton Variant="Variant.Text"
                                           Color="Color.Secondary"
                                           Disabled="@isSuperAdminSubmitting"
                                           OnClick="CancelCreateSuperAdmin">
                                    Cancel
                                </MudButton>
                                <MudButton ButtonType="ButtonType.Submit"
                                           Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Disabled="@isSuperAdminSubmitting">
                                    @(isSuperAdminSubmitting ? "Creating..." : "Create Backup SuperAdmin")
                                </MudButton>
                            </div>
                        </EditForm>
                    </MudPaper>
                }

                <MudTable Items="@superAdmins" Dense="true" Hover="true" Elevation="0" Breakpoint="Breakpoint.Sm" Class="shadcn-table">
                    <HeaderContent>
                        <MudTh>Name</MudTh>
                        <MudTh>Email</MudTh>
                        <MudTh>Email Confirmation</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Created</MudTh>
                        <MudTh Style="text-align: right;">Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate Context="admin">
                        <MudTd DataLabel="Name">
                            <div class="d-flex align-center gap-2" style="font-weight: 500; color: var(--text-main);">
                                <MudIcon Icon="@Icons.Material.Outlined.AdminPanelSettings" Size="Size.Small" Style="color: var(--text-muted);" />
                                @admin.FullName
                                @if (admin.IsCurrentUser)
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">You</MudChip>
                                }
                            </div>
                        </MudTd>
                        <MudTd DataLabel="Email">
                            <div style="color: var(--text-muted); font-size: 0.875rem;">@admin.Email</div>
                        </MudTd>
                        <MudTd DataLabel="Email Confirmation">
                            <span class="shadcn-badge @(admin.EmailConfirmed ? "badge-green" : "badge-orange")">
                                @(admin.EmailConfirmed ? "Confirmed" : "Pending")
                            </span>
                        </MudTd>
                        <MudTd DataLabel="Status">
                            <span class="shadcn-badge @GetStatusBadgeClass(admin.Status)">
                                @admin.Status
                            </span>
                        </MudTd>
                        <MudTd DataLabel="Created" Style="white-space: nowrap;">
                            <div style="color: var(--text-muted); font-size: 0.875rem;">@admin.CreatedAt.ToString("MMM dd, yyyy")</div>
                        </MudTd>
                        <MudTd DataLabel="Actions" Style="text-align: right;">
                            <MudMenu Icon="@Icons.Material.Outlined.MoreVert" Dense="true" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                                @if (admin.Status != "Active")
                                {
                                    <MudMenuItem Icon="@Icons.Material.Outlined.CheckCircleOutline"
                                                 OnClick="@(() => ConfirmActivateSuperAdmin(admin))">
                                        Activate
                                    </MudMenuItem>
                                }
                                @if (admin.Status == "Active")
                                {
                                    <MudMenuItem Icon="@Icons.Material.Outlined.Block"
                                                 Disabled="@(admin.IsCurrentUser || IsLastActiveSuperAdmin(admin))"
                                                 Style="color: var(--color-destructive);"
                                                 OnClick="@(() => ConfirmBlockSuperAdmin(admin))">
                                        Block
                                    </MudMenuItem>
                                }
                            </MudMenu>
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <div style="text-align: center; padding: 2rem; color: var(--text-muted);">
                            No SuperAdmin accounts found.
                        </div>
                    </NoRecordsContent>
                </MudTable>
            </MudCardContent>
        </MudCard>

        <div class="sa-stats-grid">
            <div class="sa-metric-card">
                <div class="sa-metric-header">
                    <div class="sa-metric-label">Active</div>
                    <div class="sa-metric-icon-wrapper" style="background-color: #d1fae5;">
                        <MudIcon Icon="@Icons.Material.Outlined.CheckCircleOutline" Size="Size.Small" Style="color: #10b981;" />
                    </div>
                </div>
                <div class="sa-metric-value">@users.Count(u => u.Status == "Active")</div>
            </div>

            <div class="sa-metric-card">
                <div class="sa-metric-header">
                    <div class="sa-metric-label">Restricted</div>
                    <div class="sa-metric-icon-wrapper" style="background-color: #fef3c7;">
                        <MudIcon Icon="@Icons.Material.Outlined.WarningAmber" Size="Size.Small" Style="color: #f59e0b;" />
                    </div>
                </div>
                <div class="sa-metric-value">@users.Count(u => u.Status == "Restricted")</div>
            </div>

            <div class="sa-metric-card">
                <div class="sa-metric-header">
                    <div class="sa-metric-label">Blocked</div>
                    <div class="sa-metric-icon-wrapper" style="background-color: #fef2f2;">
                        <MudIcon Icon="@Icons.Material.Outlined.Block" Size="Size.Small" Style="color: #ef4444;" />
                    </div>
                </div>
                <div class="sa-metric-value">@users.Count(u => u.Status == "Blocked")</div>
            </div>

            <div class="sa-metric-card">
                <div class="sa-metric-header">
                    <div class="sa-metric-label">Companies</div>
                    <div class="sa-metric-icon-wrapper" style="background-color: #f3e8ff;">
                        <MudIcon Icon="@Icons.Material.Outlined.Business" Size="Size.Small" Style="color: #8b5cf6;" />
                    </div>
                </div>
                <div class="sa-metric-value">@users.Select(u => u.CompanyName).Distinct().Count()</div>
            </div>
        </div>

        <MudCard Elevation="0" Outlined="true" Class="shadcn-card">
            <MudTable Items="@users" Hover="true" Loading="@isLoading" Filter="new Func<GlobalUserDTO, bool>(FilterFunc)"
                      Dense="false" Elevation="0" Class="shadcn-table" Breakpoint="Breakpoint.Sm">
                <ToolBarContent>
                    <div class="table-toolbar-wrapper">
                        <span class="table-toolbar-title">All System Users</span>

                        <div class="table-toolbar-actions">
                            <MudTextField @bind-Value="searchString"
                                          Placeholder="Search users or companies..."
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Outlined.Search"
                                          IconSize="Size.Small"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"                    
                                          Class="shadcn-input filter-search" />

                            <MudSelect T="string"
                                       @bind-Value="statusFilter"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       Class="shadcn-input filter-dropdown">
                                <MudSelectItem T="string" Value='@("All")'>All Statuses</MudSelectItem>
                                <MudSelectItem T="string" Value='@("Active")'>Active</MudSelectItem>
                                <MudSelectItem T="string" Value='@("Restricted")'>Restricted</MudSelectItem>
                                <MudSelectItem T="string" Value='@("Blocked")'>Blocked</MudSelectItem>
                            </MudSelect>

                            <MudSelect T="string"
                                       @bind-Value="roleFilter"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       Class="shadcn-input filter-dropdown">
                                <MudSelectItem T="string" Value='@("All")'>All Roles</MudSelectItem>
                                <MudSelectItem T="string" Value='@("Admin")'>Admin</MudSelectItem>
                                <MudSelectItem T="string" Value='@("Accounting")'>Accounting</MudSelectItem>
                                <MudSelectItem T="string" Value='@("Management")'>Management</MudSelectItem>
                            </MudSelect>
                        </div>
                    </div>
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>Company</MudTh>
                    <MudTh>Full Name</MudTh>
                    <MudTh>Email</MudTh>
                    <MudTh>Role</MudTh>
                    <MudTh>Joined</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh Style="text-align: right;">Actions</MudTh>
                </HeaderContent>
                <RowTemplate Context="context">
                    <MudTd DataLabel="Company">
                        <div class="d-flex align-center gap-2" style="color: var(--text-main); font-weight: 500;">
                            <MudIcon Icon="@Icons.Material.Outlined.Business" Size="Size.Small" Style="color: var(--text-muted);" />
                            @context.CompanyName
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Name">
                        <div style="font-weight: 500; color: var(--text-main);">@context.FullName</div>
                    </MudTd>
                    <MudTd DataLabel="Email">
                        <div style="color: var(--text-muted); font-size: 0.875rem;">@context.Email</div>
                    </MudTd>
                    <MudTd DataLabel="Role">
                        <span class="shadcn-badge @GetRoleBadgeClass(context.Role)">
                            @context.Role
                        </span>
                    </MudTd>
                    <MudTd DataLabel="Joined" Style="white-space: nowrap;">
                        <div style="color: var(--text-muted); font-size: 0.875rem;">@context.CreatedAt.ToString("MMM dd, yyyy")</div>
                    </MudTd>
                    <MudTd DataLabel="Status">
                        @switch (context.Status)
                        {
                            case "Active":
                                <span class="shadcn-badge badge-green">Active</span>
                                break;
                            case "Restricted":
                                <span class="shadcn-badge badge-orange">Restricted</span>
                                break;
                            case "Blocked":
                                <span class="shadcn-badge badge-red">Blocked</span>
                                break;
                            default:
                                <span class="shadcn-badge badge-slate">@context.Status</span>
                                break;
                        }
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <MudMenu Icon="@Icons.Material.Outlined.MoreVert" Dense="true" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                            @if (context.Status != "Active")
                            {
                                <MudMenuItem Icon="@Icons.Material.Outlined.CheckCircleOutline"
                                             OnClick="@(() => ConfirmActivateUser(context))">
                                    Activate
                                </MudMenuItem>
                            }
                            @if (context.Status != "Restricted")
                            {
                                <MudMenuItem Icon="@Icons.Material.Outlined.WarningAmber"
                                             OnClick="@(() => ConfirmRestrictUser(context))">
                                    Restrict
                                </MudMenuItem>
                            }
                            @if (context.Status != "Blocked")
                            {
                                <MudMenuItem Icon="@Icons.Material.Outlined.Block"
                                             Style="color: var(--color-destructive);"
                                             OnClick="@(() => ConfirmBlockUser(context))">
                                    Block
                                </MudMenuItem>
                            }
                        </MudMenu>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudCard>
    }
</MudContainer>

@code {
    private List<GlobalUserDTO> users = new List<GlobalUserDTO>();
    private List<SuperAdminAccountDTO> superAdmins = new List<SuperAdminAccountDTO>();
    private MfaStatusDTO currentMfaStatus = new();
    private CreateSuperAdminDTO createSuperAdminModel = new();
    private bool isLoading = true;
    private bool showCreateSuperAdmin;
    private bool isSuperAdminSubmitting;
    private string searchString = "";
    private string statusFilter = "All";
    private string roleFilter = "All";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            users = await SuperAdminService.GetAllUsersAsync();
            superAdmins = await SuperAdminService.GetSuperAdminAccountsAsync();

            try
            {
                currentMfaStatus = await AuthService.GetMfaStatus();
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Unable to load current SuperAdmin MFA status for step-up verification UX hints.");
                currentMfaStatus = new MfaStatusDTO();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load global users.");
            Snackbar.Add("Failed to load users. Please try again.", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ToggleCreateSuperAdmin()
    {
        showCreateSuperAdmin = !showCreateSuperAdmin;
        if (!showCreateSuperAdmin)
        {
            createSuperAdminModel = new CreateSuperAdminDTO();
        }
    }

    private void CancelCreateSuperAdmin()
    {
        showCreateSuperAdmin = false;
        createSuperAdminModel = new CreateSuperAdminDTO();
    }

    private async Task HandleCreateSuperAdminAsync()
    {
        isSuperAdminSubmitting = true;
        try
        {
            var stepUp = await RequestStepUpVerificationAsync("Create Backup SuperAdmin", createSuperAdminModel.Email);
            if (stepUp == null)
            {
                return;
            }

            await SuperAdminService.CreateSuperAdminAsync(new CreateSuperAdminRequestDTO
            {
                SuperAdmin = createSuperAdminModel,
                StepUp = stepUp
            });
            Snackbar.Add("Backup SuperAdmin created. Ask them to confirm email and enable MFA.", Severity.Success);
            CancelCreateSuperAdmin();
            await LoadData();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to create backup SuperAdmin.");
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            isSuperAdminSubmitting = false;
        }
    }

    private async Task ChangeSuperAdminStatus(SuperAdminAccountDTO admin, string newStatus)
    {
        try
        {
            var actionDescription = newStatus == "Active"
                ? "Enable SuperAdmin account"
                : "Disable SuperAdmin account";
            var stepUp = await RequestStepUpVerificationAsync(actionDescription, admin.Email);
            if (stepUp == null)
            {
                return;
            }

            await SuperAdminService.UpdateSuperAdminStatusAsync(
                admin.Id,
                new UpdateSuperAdminStatusRequestDTO
                {
                    Status = newStatus,
                    StepUp = stepUp
                });
            admin.Status = newStatus;
            admin.IsActive = newStatus == "Active";
            Snackbar.Add($"SuperAdmin '{admin.Email}' is now {newStatus}.", Severity.Success);
            await LoadData();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to update SuperAdmin status for user id {UserId}.", admin.Id);
            Snackbar.Add(ex.Message, Severity.Error);
            await LoadData();
        }
    }

    private async Task ConfirmActivateSuperAdmin(SuperAdminAccountDTO admin)
    {
        var result = await ShowConfirmDialog(
            $"Activate SuperAdmin '{admin.FullName}'?",
            $"{admin.Email} will regain platform-level governance access.",
            "Activate",
            Color.Success);

        if (result) await ChangeSuperAdminStatus(admin, "Active");
    }

    private async Task ConfirmBlockSuperAdmin(SuperAdminAccountDTO admin)
    {
        var result = await ShowConfirmDialog(
            $"Block SuperAdmin '{admin.FullName}'?",
            $"{admin.Email} will be prevented from signing in. At least one other active SuperAdmin must remain.",
            "Block",
            Color.Error);

        if (result) await ChangeSuperAdminStatus(admin, "Blocked");
    }

    private async Task ChangeUserStatus(GlobalUserDTO user, string newStatus)
    {
        try
        {
            await SuperAdminService.UpdateUserStatusAsync(user.Id, newStatus);
            user.Status = newStatus;
            user.IsActive = newStatus == "Active";
            Snackbar.Add($"'{user.Email}' is now {newStatus}.", Severity.Success);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to update status for user id {UserId}.", user.Id);
            Snackbar.Add("Unable to update user status. Please try again.", Severity.Error);
            await LoadData();
        }
    }

    private async Task ConfirmActivateUser(GlobalUserDTO user)
    {
        var result = await ShowConfirmDialog(
            $"Activate user '{user.FullName}'?",
            $"{user.Email} will be granted full access to their role in the system.",
            "Activate",
            Color.Success);

        if (result) await ChangeUserStatus(user, "Active");
    }

    private async Task ConfirmRestrictUser(GlobalUserDTO user)
    {
        var result = await ShowConfirmDialog(
            $"Restrict user '{user.FullName}'?",
            $"{user.Email} will have limited access within the system.",
            "Restrict",
            Color.Warning);

        if (result) await ChangeUserStatus(user, "Restricted");
    }

    private async Task ConfirmBlockUser(GlobalUserDTO user)
    {
        var result = await ShowConfirmDialog(
            $"Block user '{user.FullName}'?",
            $"{user.Email} will be completely prevented from logging in until unblocked.",
            "Block",
            Color.Error);

        if (result) await ChangeUserStatus(user, "Blocked");
    }

    private string GetRoleBadgeClass(string? role) => role switch
    {
        "Admin"      => "badge-indigo",
        "Accounting" => "badge-blue",
        "Management" => "badge-slate",
        _            => "badge-slate"
    };

    private string GetStatusBadgeClass(string? status) => status switch
    {
        "Active" => "badge-green",
        "Restricted" => "badge-orange",
        "Blocked" => "badge-red",
        _ => "badge-slate"
    };

    private bool IsLastActiveSuperAdmin(SuperAdminAccountDTO admin)
    {
        return admin.Status == "Active" &&
               admin.IsActive &&
               superAdmins.Count(candidate => candidate.Status == "Active" && candidate.IsActive) <= 1;
    }

    private async Task<bool> ShowConfirmDialog(string content, string subText, string buttonText, Color color)
    {
        var parameters = new DialogParameters
        {
            [nameof(ShadcnConfirmDialog.ContentText)] = content,
            [nameof(ShadcnConfirmDialog.SubText)]     = subText,
            [nameof(ShadcnConfirmDialog.ButtonText)]  = buttonText,
            [nameof(ShadcnConfirmDialog.Color)]       = color
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
        var dialog  = await DialogService.ShowAsync<ShadcnConfirmDialog>("Confirm", parameters, options);
        var dialogResult = await dialog.Result;
        return dialogResult is not null && !dialogResult.Canceled;
    }

    private async Task<SuperAdminStepUpVerificationDTO?> RequestStepUpVerificationAsync(string actionDescription, string targetDisplay)
    {
        var parameters = new DialogParameters
        {
            [nameof(SuperAdminStepUpDialog.ActionDescription)] = actionDescription,
            [nameof(SuperAdminStepUpDialog.TargetDisplay)] = targetDisplay,
            [nameof(SuperAdminStepUpDialog.IsAuthenticatorAppEnabled)] = currentMfaStatus.IsAuthenticatorAppEnabled,
            [nameof(SuperAdminStepUpDialog.IsEmailOtpEnabled)] = currentMfaStatus.IsEmailOtpEnabled
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseButton = true,
            CloseOnEscapeKey = false
        };

        var dialog = await DialogService.ShowAsync<SuperAdminStepUpDialog>("Verify Identity", parameters, options);
        var result = await dialog.Result;

        if (result?.Canceled != false || result.Data is not SuperAdminStepUpVerificationDTO stepUp)
        {
            return null;
        }

        return stepUp;
    }

    private bool FilterFunc(GlobalUserDTO element)
    {
        bool matchesSearch = string.IsNullOrWhiteSpace(searchString) ||
            (element.Email?.Contains(searchString, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (element.CompanyName?.Contains(searchString, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (element.FullName?.Contains(searchString, StringComparison.OrdinalIgnoreCase) ?? false);

        bool matchesStatus = statusFilter == "All" || element.Status == statusFilter;
        bool matchesRole   = roleFilter   == "All" || element.Role   == roleFilter;

        return matchesSearch && matchesStatus && matchesRole;
    }
}
