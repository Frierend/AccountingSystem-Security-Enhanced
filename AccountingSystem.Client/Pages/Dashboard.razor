@page "/dashboard"
@using AccountingSystem.Shared.DTOs
@using AccountingSystem.Client.Services
@using MudBlazor
@using Heron.MudCalendar
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

@inject ReportService ReportService
@inject LedgerService LedgerService
@inject PayableService PayableService
@inject ReceivableService ReceivableService
@inject WorldBankService WorldBankService
@inject FrankfurterService FrankfurterService
@inject ILogger<Dashboard> Logger

<PageTitle>Financial Dashboard - AccSys</PageTitle>

<style>
    :root {
        --border-color: #e2e8f0;
        --bg-background: #f8fafc;
        --bg-surface: #ffffff;
        --bg-muted: #f1f5f9;
        --text-main: #0f172a;
        --text-muted: #64748b;
        --radius-lg: 8px;
        --radius-md: 6px;
        --color-success: #10b981;
        --color-destructive: #ef4444;
        --color-warning: #f59e0b;
    }

    .dashboard-grid {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        gap: 1.5rem;
    }

    .span-3 { grid-column: span 3; }
    .span-4 { grid-column: span 4; }
    .span-6 { grid-column: span 6; }
    .span-8 { grid-column: span 8; }
    .span-12 { grid-column: span 12; }

    @@media (max-width: 1400px) {
        .span-3, .span-4 { grid-column: span 6; }
    }

    @@media (max-width: 768px) {
        .span-3, .span-4, .span-6, .span-8 { grid-column: span 12; }
    }

    .dashboard-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        gap: 1rem;
    }

    .progress-container {
        display: flex;
        gap: 2rem;
        margin-bottom: 2rem;
    }

    .stat-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0.75rem;
        margin-top: auto;
    }

    @@media (max-width: 768px) {
        .dashboard-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .progress-container {
            flex-direction: column;
            gap: 1rem;
        }

        .stat-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    .shadcn-card {
        background-color: var(--bg-surface);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-lg);
        padding: 1.5rem;
        box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
        display: flex;
        flex-direction: column;
        height: 100%;
        transition: box-shadow 0.2s ease;
    }

    .shadcn-card:hover {
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -2px rgba(0, 0, 0, 0.05);
    }

    .shadcn-card-header {
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: space-between;
        padding-bottom: 0.5rem;
    }

    .shadcn-card-title {
        font-size: 0.875rem;
        font-weight: 500;
        letter-spacing: -0.025em;
        color: var(--text-main);
    }

    .shadcn-card-icon {
        color: var(--text-muted);
        opacity: 0.8;
    }

    .metric-value-huge {
        font-size: 2rem;
        font-weight: 700;
        letter-spacing: -0.05em;
        color: var(--text-main);
        line-height: 1.2;
    }

    .metric-subtitle {
        font-size: 0.75rem;
        color: var(--text-muted);
        margin-top: 0.25rem;
    }

    .flat-progress-bg {
        height: 8px;
        background-color: var(--bg-muted);
        border-radius: 9999px;
        overflow: hidden;
        margin-top: 0.5rem;
    }

    .flat-progress-fill {
        height: 100%;
        border-radius: 9999px;
    }

    .shadcn-input {
        background: var(--bg-surface);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-md);
        padding: 0.5rem 0.75rem;
        font-size: 0.875rem;
        color: var(--text-main);
        width: 100%;
        transition: outline 0.15s ease;
    }

    .shadcn-input:focus {
        outline: 2px solid var(--text-main);
        outline-offset: -1px;
    }

    .shadcn-btn-outline {
        border: 1px solid var(--border-color) !important;
        background: var(--bg-surface) !important;
        color: var(--text-main) !important;
        border-radius: var(--radius-md) !important;
        text-transform: none !important;
        font-weight: 500 !important;
        box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05) !important;
    }

    .shadcn-btn-outline:hover {
        background: var(--bg-muted) !important;
    }

    .list-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.75rem 0;
        border-bottom: 1px solid var(--border-color);
    }

    .list-row:last-child {
        border-bottom: none;
    }

    .stat-grid-item {
        padding: 1rem;
        border-radius: var(--radius-md);
        border: 1px solid var(--border-color);
        background: var(--bg-surface);
    }

    .trend-icon {
        font-size: 16px !important;
        display: flex;
    }
</style>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4 mb-10">

    <div class="dashboard-header">
        <div>
            @if (isLoading)
            {
                <MudSkeleton SkeletonType="SkeletonType.Text" Width="200px" Height="32px" Class="mb-1" />
                <MudSkeleton SkeletonType="SkeletonType.Text" Width="150px" Height="16px" />
            }
            else
            {
                <h2 style="font-size: 1.875rem; font-weight: 700; letter-spacing: -0.025em; color: var(--text-main); margin: 0;">
                    Dashboard
                </h2>
                <p style="color: var(--text-muted); font-size: 0.875rem; margin: 0.25rem 0 0 0;">
                    Overview of your financial and economic metrics.
                </p>
            }
        </div>
        @if (!isLoading)
        {
            <MudButton Variant="Variant.Outlined" Class="shadcn-btn-outline" StartIcon="@Icons.Material.Outlined.Refresh"
                Size="Size.Small" OnClick="LoadData">
                Refresh Data
            </MudButton>
        }
    </div>

    @if (isLoading)
    {
        <div class="dashboard-grid">
            <div class="span-6"><MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="100%" Height="350px" Style="border-radius: 8px;" /></div>
            <div class="span-3"><MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="100%" Height="350px" Style="border-radius: 8px;" /></div>
            <div class="span-3"><MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="100%" Height="350px" Style="border-radius: 8px;" /></div>
            <div class="span-6"><MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="100%" Height="400px" Style="border-radius: 8px;" /></div>
            <div class="span-6"><MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="100%" Height="400px" Style="border-radius: 8px;" /></div>
        </div>
    }
    else
    {
        <div class="dashboard-grid">

            <div class="span-6">
                <div class="shadcn-card">
                    <div class="shadcn-card-header">
                        <span class="shadcn-card-title">Financial Summary</span>
                        <MudIcon Icon="@Icons.Material.Outlined.AccountBalance" Size="Size.Small" Class="shadcn-card-icon" />
                    </div>

                    <div style="margin-bottom: 2rem; margin-top: 0.5rem;">
                        <div style="font-size: 0.875rem; font-weight: 500; color: var(--text-muted); margin-bottom: 0.25rem; display: flex; align-items: center; gap: 4px;">
                            Net Profit
                            @if (NetProfit >= 0)
                            {
                                <MudIcon Icon="@Icons.Material.Outlined.TrendingUp" Class="trend-icon" Style="color: var(--color-success);" />
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Outlined.TrendingDown" Class="trend-icon" Style="color: var(--color-destructive);" />
                            }
                        </div>
                        <div style="font-size: 2.5rem; font-weight: 700; letter-spacing: -0.05em; color: var(--text-main); line-height: 1;">
                            ₱@FormatCompact(NetProfit)
                        </div>
                    </div>

                    <div class="progress-container">
                        <div style="flex: 1;">
                            <div style="display: flex; justify-content: space-between; align-items: baseline;">
                                <span style="font-size: 0.875rem; color: var(--text-main); font-weight: 500;">Revenue</span>
                                <span style="font-size: 0.875rem; color: var(--text-muted);">₱@FormatCompact(TotalRevenue)</span>
                            </div>
                            <div class="flat-progress-bg">
                                <div class="flat-progress-fill" style="width: @(TotalRevenue > 0 && TotalRevenue >= TotalExpenses ? 100 : (TotalExpenses > 0 ? (double)TotalRevenue / (double)TotalExpenses * 100 : 0))%; background-color: var(--text-main);"></div>
                            </div>
                        </div>
                        <div style="flex: 1;">
                            <div style="display: flex; justify-content: space-between; align-items: baseline;">
                                <span style="font-size: 0.875rem; color: var(--text-main); font-weight: 500;">Expenses</span>
                                <span style="font-size: 0.875rem; color: var(--text-muted);">₱@FormatCompact(TotalExpenses)</span>
                            </div>
                            <div class="flat-progress-bg">
                                <div class="flat-progress-fill" style="width: @(TotalExpenses > 0 && TotalExpenses >= TotalRevenue ? 100 : (TotalRevenue > 0 ? (double)TotalExpenses / (double)TotalRevenue * 100 : 0))%; background-color: var(--text-muted);"></div>
                            </div>
                        </div>
                    </div>

                    <div class="stat-grid">
                        <div class="stat-grid-item">
                            <div style="font-size: 0.75rem; color: var(--text-muted); margin-bottom: 0.25rem; display: flex; align-items: center; gap: 4px;">
                                Cash
                                @if (CashBalance >= 0)
                                {
                                    <MudIcon Icon="@Icons.Material.Outlined.TrendingUp" Style="font-size: 14px; color: var(--color-success);" />
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Outlined.TrendingDown" Style="font-size: 14px; color: var(--color-destructive);" />
                                }
                            </div>
                            <div style="font-size: 1.125rem; font-weight: 600; color: var(--text-main);">₱@FormatCompact(CashBalance)</div>
                        </div>
                        <div class="stat-grid-item">
                            <div style="font-size: 0.75rem; color: var(--text-muted); margin-bottom: 0.25rem; display: flex; align-items: center; gap: 4px;">
                                Assets
                                @if (TotalAssets >= 0)
                                {
                                    <MudIcon Icon="@Icons.Material.Outlined.TrendingUp" Style="font-size: 14px; color: var(--color-success);" />
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Outlined.TrendingDown" Style="font-size: 14px; color: var(--color-destructive);" />
                                }
                            </div>
                            <div style="font-size: 1.125rem; font-weight: 600; color: var(--text-main);">₱@FormatCompact(TotalAssets)</div>
                        </div>
                        <div class="stat-grid-item">
                            <div style="font-size: 0.75rem; color: var(--text-muted); margin-bottom: 0.25rem;">
                                Liabilities
                            </div>
                            <div style="font-size: 1.125rem; font-weight: 600; color: var(--text-main);">₱@FormatCompact(TotalLiabilities)</div>
                        </div>
                        <div class="stat-grid-item">
                            <div style="font-size: 0.75rem; color: var(--text-muted); margin-bottom: 0.25rem; display: flex; align-items: center; gap: 4px;">
                                Margin
                                @if (ProfitMarginPercent >= 0)
                                {
                                    <MudIcon Icon="@Icons.Material.Outlined.TrendingUp" Style="font-size: 14px; color: var(--color-success);" />
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Outlined.TrendingDown" Style="font-size: 14px; color: var(--color-destructive);" />
                                }
                            </div>
                            <div style="font-size: 1.125rem; font-weight: 600; color: var(--text-main);">@ProfitMarginPercent.ToString("F1")%</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="span-3">
                <div class="shadcn-card">
                    <div class="shadcn-card-header">
                        <span class="shadcn-card-title">Active Transactions</span>
                        <MudIcon Icon="@Icons.Material.Outlined.SwapHoriz" Size="Size.Small" Class="shadcn-card-icon" />
                    </div>

                    <div style="margin-top: 0.5rem; margin-bottom: 1.5rem;">
                        <div class="metric-value-huge">@ActiveTransactions</div>
                        <div class="metric-subtitle">Pending payments & collections</div>
                    </div>

                    <div style="display: flex; flex-direction: column; gap: 0.5rem; margin-top: auto;">
                        <div style="border: 1px solid var(--border-color); border-radius: var(--radius-md); padding: 1rem; display: flex; justify-content: space-between; align-items: center;">
                            <div>
                                <div style="font-size: 0.875rem; font-weight: 500; color: var(--text-main);">Receivables</div>
                                <div style="font-size: 0.75rem; color: var(--text-muted);">@InvoicesToCollect invoices</div>
                            </div>
                            <div style="text-align: right;">
                                <div style="font-size: 1rem; font-weight: 600; color: var(--color-success);">₱@FormatCompact(ArOutstanding)</div>
                            </div>
                        </div>
                        <div style="border: 1px solid var(--border-color); border-radius: var(--radius-md); padding: 1rem; display: flex; justify-content: space-between; align-items: center;">
                            <div>
                                <div style="font-size: 0.875rem; font-weight: 500; color: var(--text-main);">Payables</div>
                                <div style="font-size: 0.75rem; color: var(--text-muted);">@BillsToPay bills</div>
                            </div>
                            <div style="text-align: right;">
                                <div style="font-size: 1rem; font-weight: 600; color: var(--color-destructive);">₱@FormatCompact(ApOutstanding)</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="span-3">
                <div class="shadcn-card">
                    <div class="shadcn-card-header">
                        <span class="shadcn-card-title">Currency Converter</span>
                        <MudIcon Icon="@Icons.Material.Outlined.CurrencyExchange" Size="Size.Small" Class="shadcn-card-icon" />
                    </div>

                    @if (isForexLoading)
                    {
                        <div style="padding: 2rem; text-align: center;">
                            <MudProgressCircular Color="Color.Default" Indeterminate="true" Size="Size.Small" />
                        </div>
                    }
                    else
                    {
                        <div style="margin-top: 0.5rem; margin-bottom: 1.5rem;">
                            <div class="metric-value-huge">
                                ₱@((usdInputAmount * exchangeRate).ToString("N2"))
                            </div>
                            <div class="metric-subtitle">
                                1 @baseCurrency = ₱@exchangeRate.ToString("F4") PHP
                            </div>
                        </div>

                        <div style="margin-top: auto; display: flex; flex-direction: column; gap: 0.75rem;">
                            <div style="display: flex; gap: 0.5rem;">
                                <div style="flex: 1;">
                                    <label style="font-size: 0.7rem; color: var(--text-muted); font-weight: 500;">FROM</label>
                                    <select class="shadcn-input" value="@baseCurrency" @onchange="OnBaseCurrencyChanged" style="height: 36px; padding: 2px 8px;">
                                        @foreach (var curr in allCurrencies)
                                        {
                                            <option value="@curr.Key" selected="@(curr.Key == baseCurrency)">@curr.Key - @curr.Value</option>
                                        }
                                    </select>
                                </div>
                                <div style="flex: 1;">
                                    <label style="font-size: 0.7rem; color: var(--text-muted); font-weight: 500;">TO</label>
                                    <input class="shadcn-input" value="PHP - Philippine Peso" disabled
                                           style="height: 36px; padding: 2px 8px; opacity: 0.6; cursor: not-allowed;" />
                                </div>
                            </div>

                            <div>
                                <label style="font-size: 0.7rem; color: var(--text-muted); font-weight: 500;">AMOUNT (@baseCurrency)</label>
                                <input type="number" class="shadcn-input" @bind-value="usdInputAmount" @bind-value:event="oninput" min="0" />
                            </div>

                            <div style="display: flex; gap: 0.5rem; margin-top: 0.5rem;">
                                @foreach (var amount in new[] { 100, 500, 1000 })
                                {
                                    <button class="shadcn-btn-outline" style="flex: 1; padding: 0.25rem; font-size: 0.75rem;"
                                            @onclick="@(() => usdInputAmount = amount)">
                                        @amount
                                    </button>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="span-6">
                <div class="shadcn-card">
                    <div class="shadcn-card-header">
                        <span class="shadcn-card-title">World Bank Inflation (PH)</span>
                        <div style="display: flex; align-items: center; gap: 0.5rem;">
                            <span style="font-size: 0.75rem; font-weight: 500; color: var(--text-muted); background: var(--bg-muted); padding: 2px 8px; border-radius: 999px;">Live Data</span>
                            <MudIcon Icon="@Icons.Material.Outlined.Public" Size="Size.Small" Class="shadcn-card-icon" />
                        </div>
                    </div>

                    @if (inflationData.Any())
                    {
                        <div style="display: flex; align-items: baseline; gap: 0.5rem; margin-top: 0.5rem; margin-bottom: 1rem;">
                            <div class="metric-value-huge">@CurrentInflationValue.ToString("F1")%</div>
                            <div class="metric-subtitle">Current Rate (@inflationData.First().Date)</div>
                        </div>

                        <div style="margin: 1rem 0; flex: 1;">
                            <MudChart ChartType="ChartType.Line"
                                      ChartSeries="@inflationChartSeries"
                                      XAxisLabels="@inflationYears"
                                      Width="100%"
                                      Height="220px"
                                      ChartOptions="@inflationChartOptions">
                            </MudChart>
                        </div>

                        <div style="display: flex; justify-content: space-between; border-top: 1px solid var(--border-color); padding-top: 1rem; margin-top: auto;">
                            @{
                                var yoyChange = (inflationData.Count >= 2) ? (inflationData[0].Value ?? 0) - (inflationData[1].Value ?? 0) : 0;
                                var avg3yr = inflationData.Take(3).Where(x => x.Value.HasValue).Average(x => x.Value) ?? 0;
                            }
                            <div>
                                <div style="font-size: 0.75rem; color: var(--text-muted);">YoY Change</div>
                                <div style="font-size: 0.875rem; font-weight: 600; color: @(yoyChange >= 0 ? "var(--color-destructive)" : "var(--color-success)");">
                                    @(yoyChange >= 0 ? "+" : "")@yoyChange.ToString("F2")%
                                </div>
                            </div>
                            <div>
                                <div style="font-size: 0.75rem; color: var(--text-muted);">3-Year Average</div>
                                <div style="font-size: 0.875rem; font-weight: 600; color: var(--text-main);">@avg3yr.ToString("F2")%</div>
                            </div>
                            <div>
                                <div style="font-size: 0.75rem; color: var(--text-muted);">Status</div>
                                <div style="font-size: 0.875rem; font-weight: 600; color: var(--text-main);">@GetInflationStatus(inflationData.First().Value)</div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div style="text-align: center; padding: 3rem; color: var(--text-muted); margin: auto;">
                            <MudIcon Icon="@Icons.Material.Outlined.CloudOff" Size="Size.Medium" Class="mb-2" />
                            <div style="font-size: 0.875rem;">Loading inflation data...</div>
                        </div>
                    }
                </div>
            </div>

            <div class="span-6">
                <div class="shadcn-card">
                    <div class="shadcn-card-header" style="margin-bottom: 0.5rem;">
                        <span class="shadcn-card-title">Inflation History</span>
                        <MudIcon Icon="@Icons.Material.Outlined.History" Size="Size.Small" Class="shadcn-card-icon" />
                    </div>

                    @if (inflationData.Any())
                    {
                        <div style="flex: 1; display: flex; flex-direction: column;">
                            @foreach (var data in inflationData.Take(6))
                            {
                                var prevVal = GetPreviousInflationValue(data.Date);
                                var isUp = prevVal.HasValue && data.Value > prevVal;
                                var changeAmount = prevVal.HasValue ? data.Value - prevVal : null;

                                <div class="list-row">
                                    <div style="display: flex; align-items: center; gap: 1rem;">
                                        <span style="font-size: 0.875rem; font-weight: 500; color: var(--text-main); width: 40px;">@data.Date</span>
                                    </div>
                                    <div style="display: flex; align-items: center; gap: 1.5rem;">
                                        @if (changeAmount.HasValue)
                                        {
                                            <span style="font-size: 0.875rem; color: @(isUp ? "var(--color-destructive)" : "var(--color-success)");">
                                                @(changeAmount >= 0 ? "+" : "")@changeAmount.Value.ToString("F2")%
                                            </span>
                                        }
                                        <span style="font-size: 1rem; font-weight: 600; color: var(--text-main); width: 60px; text-align: right;">
                                            @(data.Value?.ToString("F2") ?? "N/A")%
                                        </span>
                                    </div>
                                </div>
                            }
                        </div>

                        <div style="display: flex; gap: 1rem; margin-top: auto; padding-top: 1rem;">
                            <div style="flex: 1; background: var(--bg-muted); padding: 0.75rem 1rem; border-radius: var(--radius-md); display: flex; justify-content: space-between; align-items: center;">
                                <span style="font-size: 0.75rem; color: var(--text-muted); font-weight: 500;">5-Year Avg</span>
                                <span style="font-size: 0.875rem; font-weight: 600; color: var(--text-main);">
                                    @(inflationData.Take(5).Where(x => x.Value.HasValue).Average(x => x.Value)?.ToString("F2") ?? "N/A")%
                                </span>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div style="text-align: center; padding: 2rem; color: var(--text-muted); margin: auto;">
                            <MudIcon Icon="@Icons.Material.Outlined.CloudOff" Size="Size.Medium" Class="mb-2" />
                            <div style="font-size: 0.875rem;">Loading inflation data...</div>
                        </div>
                    }
                </div>
            </div>

        </div>
    }

</MudContainer>

@code {
    // --- State ---
    private TrialBalanceDTO? trialBalance;
    private Dictionary<string, string> accountTypes = new();
    private List<CalendarItem> _events = new();
    private bool isLoading = false;
    private bool isForexLoading = false;

    // --- Inflation ---
    private List<WorldBankDataPoint> inflationData = new();
    private List<ChartSeries> inflationChartSeries = new();
    private string[] inflationYears = Array.Empty<string>();
    private ChartOptions inflationChartOptions = new();

    // --- Currency Converter ---
    private static readonly Dictionary<string, string> allCurrencies = new()
    {
        { "USD", "US Dollar" },
        { "EUR", "Euro" },
        { "JPY", "Japanese Yen" },
        { "SGD", "Singapore Dollar" },
        { "GBP", "British Pound" },
        { "AUD", "Australian Dollar" },
        { "HKD", "Hong Kong Dollar" }
    };

    private string baseCurrency  = "USD";
    private string targetCurrency = "PHP"; // always fixed
    private decimal exchangeRate  = 0;
    private decimal usdInputAmount = 100;

    // --- KPIs ---
    private decimal CashBalance;
    private decimal NetProfit;
    private decimal ArOutstanding;
    private decimal ApOutstanding;
    private decimal TotalAssets;
    private decimal TotalLiabilities;
    private decimal TotalRevenue;
    private decimal TotalExpenses;

    // --- Computed ---
    private int ActiveTransactions => BillsToPay + InvoicesToCollect;
    private int BillsToPay;
    private int InvoicesToCollect;
    private decimal CurrentInflationValue => inflationData.FirstOrDefault()?.Value ?? 0;
    private decimal ProfitMarginPercent => TotalRevenue > 0 ? (NetProfit / TotalRevenue * 100) : 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            var tbTask        = SafeLoad(() => ReportService.GetTrialBalance(), "trial balance");
            var acctsTask     = SafeLoad(() => LedgerService.GetAccountsAsync(), "chart of accounts");
            var billsTask     = SafeLoad(() => PayableService.GetBillsAsync(), "bills");
            var invoicesTask  = SafeLoad(() => ReceivableService.GetInvoicesAsync(), "invoices");
            var worldBankTask = SafeLoad(() => WorldBankService.GetInflationDataAsync(), "inflation data");

            await Task.WhenAll(tbTask, acctsTask, billsTask, invoicesTask, worldBankTask);

            trialBalance = tbTask.Result;

            var accountsList = acctsTask.Result;
            accountTypes = accountsList?.ToDictionary(a => a.Code, a => a.Type)
                           ?? new Dictionary<string, string>();

            inflationData = (worldBankTask.Result ?? new List<WorldBankDataPoint>())
                .Where(x => x.Value.HasValue)
                .OrderByDescending(x => x.Date)
                .ToList();

            PrepareInflationChartData();

            var bills    = (billsTask.Result    ?? new List<BillDTO>())   .Where(b => b.Balance > 0).ToList();
            var invoices = (invoicesTask.Result ?? new List<InvoiceDTO>()).Where(i => i.Balance > 0).ToList();

            BillsToPay        = bills.Count;
            InvoicesToCollect = invoices.Count;

            if (trialBalance != null)
                CalculateKPIs(trialBalance.Accounts);

            _events.Clear();
            foreach (var bill in bills)
                _events.Add(new CalendarItem { Start = bill.DueDate, Text = $"PAY: {bill.VendorName} (₱{bill.Balance:N0})" });
            foreach (var inv in invoices)
                _events.Add(new CalendarItem { Start = inv.DueDate, Text = $"COLLECT: {inv.CustomerName} (₱{inv.Balance:N0})" });

            await RefreshExchangeRate();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load dashboard data.");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task<T?> SafeLoad<T>(Func<Task<T>> loader, string label)
    {
        try
        {
            return await loader();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load dashboard metric {MetricLabel}.", label);
            return default;
        }
    }

    private async Task OnBaseCurrencyChanged(ChangeEventArgs e)
    {
        baseCurrency = e.Value?.ToString() ?? baseCurrency;
        await RefreshExchangeRate();
    }

    private async Task RefreshExchangeRate()
    {
        isForexLoading = true;
        StateHasChanged();
        try
        {
            exchangeRate = await FrankfurterService.GetExchangeRateAsync(baseCurrency, targetCurrency);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to refresh forex exchange rate.");
            exchangeRate = 0;
        }
        finally
        {
            isForexLoading = false;
            StateHasChanged();
        }
    }

    private void PrepareInflationChartData()
    {
        if (!inflationData.Any()) return;

        var chartData = inflationData.Take(10).Reverse().ToList();
        inflationYears = chartData.Select(d => d.Date ?? "").ToArray();

        inflationChartSeries = new List<ChartSeries>
        {
            new ChartSeries
            {
                Name = "Inflation Rate (%)",
                Data = chartData.Select(d => (double)(d.Value ?? 0)).ToArray()
            }
        };

        // By changing this to use var(--text-main), the chart automatically handles light & dark mode!
        inflationChartOptions = new ChartOptions
        {
            YAxisTicks          = 1,
            MaxNumYAxisTicks    = 10,
            YAxisLines          = true,
            XAxisLines          = false,
            LineStrokeWidth     = 2,
            ChartPalette        = new[] { "var(--text-main)", "var(--text-muted)" }, 
            InterpolationOption = InterpolationOption.Straight
        };
    }

    private void CalculateKPIs(List<AccountBalanceDTO> balances)
    {
        CashBalance = balances
            .Where(a => a.AccountCode == "1000" || a.AccountCode == "1010" || a.AccountCode == "1020")
            .Sum(a => a.Debit - a.Credit);

        var arAcct = balances.FirstOrDefault(a => a.AccountCode == "1100");
        ArOutstanding = arAcct != null ? arAcct.Debit - arAcct.Credit : 0;

        var apAcct = balances.FirstOrDefault(a => a.AccountCode == "2000");
        ApOutstanding = apAcct != null ? apAcct.Credit - apAcct.Debit : 0;

        TotalAssets = balances
            .Where(a => accountTypes.ContainsKey(a.AccountCode) && accountTypes[a.AccountCode] == "Asset")
            .Sum(a => a.Debit - a.Credit);

        TotalLiabilities = balances
            .Where(a => accountTypes.ContainsKey(a.AccountCode) && accountTypes[a.AccountCode] == "Liability")
            .Sum(a => a.Credit - a.Debit);

        TotalRevenue = balances
            .Where(a => accountTypes.ContainsKey(a.AccountCode) && accountTypes[a.AccountCode] == "Revenue")
            .Sum(a => a.Credit - a.Debit);

        TotalExpenses = balances
            .Where(a => accountTypes.ContainsKey(a.AccountCode) && accountTypes[a.AccountCode] == "Expense")
            .Sum(a => a.Debit - a.Credit);

        NetProfit = TotalRevenue - TotalExpenses;
    }

    private string FormatCompact(decimal value)
    {
        var absValue = Math.Abs(value);
        var sign = value < 0 ? "-" : "";

        if (absValue >= 1_000_000_000) return $"{sign}{absValue / 1_000_000_000:F1}B";
        if (absValue >= 1_000_000)     return $"{sign}{absValue / 1_000_000:F1}M";
        if (absValue >= 1_000)         return $"{sign}{absValue / 1_000:F1}K";
        return $"{sign}{absValue:N0}";
    }

    private string GetInflationStatus(decimal? value)
    {
        if (!value.HasValue) return "No Data";
        if (value < 2)       return "Low";
        if (value <= 4)      return "Moderate";
        return "High";
    }

    private decimal? GetPreviousInflationValue(string? currentYear)
    {
        if (string.IsNullOrEmpty(currentYear) || !int.TryParse(currentYear, out int year)) return null;
        return inflationData.FirstOrDefault(x => x.Date == (year - 1).ToString())?.Value;
    }
}
