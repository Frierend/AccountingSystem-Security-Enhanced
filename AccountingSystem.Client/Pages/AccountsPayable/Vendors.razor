@page "/vendors"
@using AccountingSystem.Shared.DTOs
@using AccountingSystem.Client.Services
@using AccountingSystem.Client.Shared.Dialogs
@using Microsoft.AspNetCore.Authorization
@using MudBlazor
@attribute [Authorize(Roles = "Admin,Accounting")]
@inject PayableService PayableService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject ILogger<Vendors> Logger

<PageTitle>Accounts Payable - AccSys</PageTitle>

<style>
    /* Responsive Skeletons */
    @@media (max-width: 599px) {
        .desktop-skeleton { display: none !important; }
    }
    @@media (min-width: 600px) {
        .mobile-skeleton { display: none !important; }
    }
</style>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6 mb-10">
    <div class="d-flex flex-column flex-sm-row justify-space-between align-start align-sm-center mb-6 gap-3">
        <div>
            @if (_initialLoading)
            {
                <MudSkeleton SkeletonType="SkeletonType.Text" Width="220px" Height="32px" Class="mb-1" />
                <MudSkeleton SkeletonType="SkeletonType.Text" Width="100%" Style="max-width: 420px;" Height="16px" />
            }
            else
            {
                <h2 style="font-size: 1.5rem; font-weight: 600; letter-spacing: -0.025em; color: var(--text-main); margin: 0;">
                    Vendor Management
                </h2>
                <p style="color: var(--text-muted); font-size: 0.875rem; margin: 0.25rem 0 0 0;">
                    Manage supplier relationships and track accounts payable contacts.
                </p>
            }
        </div>
        @if (_initialLoading)
        {
            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="140px" Height="36px" Style="border-radius: 6px;" />
        }
        else
        {
            <MudButton Variant="Variant.Filled"
                       Class="custom-button"
                       StartIcon="@Icons.Material.Outlined.Add"
                       Size="Size.Small"
                       OnClick="OpenAddDialog">
                Add Vendor
            </MudButton>
        }
    </div>

    @if (_initialLoading)
    {
        <MudCard Elevation="0" Outlined="true" Class="shadcn-card">
            <div class="d-flex pa-4 border-b">
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="140px" Height="24px" Class="mr-4" />
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="160px" Height="24px" Class="desktop-skeleton" />
            </div>

            <MudCardContent Class="pa-0">
                <div class="d-flex flex-column flex-sm-row justify-space-between align-start align-sm-center pa-4 border-b gap-3">
                    <MudSkeleton SkeletonType="SkeletonType.Text" Width="120px" Height="24px" />
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="100%" Style="max-width: 250px;" Height="36px" Class="rounded-md" />
                </div>

                <div class="d-flex justify-space-between mb-2 pa-4 border-b desktop-skeleton gap-2">
                    <MudSkeleton SkeletonType="SkeletonType.Text" Width="40px" Height="20px" />
                    <MudSkeleton SkeletonType="SkeletonType.Text" Width="150px" Height="20px" />
                    <MudSkeleton SkeletonType="SkeletonType.Text" Width="180px" Height="20px" />
                    <MudSkeleton SkeletonType="SkeletonType.Text" Width="120px" Height="20px" />
                    <MudSkeleton SkeletonType="SkeletonType.Text" Width="80px" Height="20px" />
                </div>

                @for (int i = 0; i < 6; i++)
                {
                    <div class="d-flex justify-space-between align-center py-3 px-4 desktop-skeleton gap-4" style="border-bottom: 1px solid var(--border-color);">
                        <div style="flex: 0.5;"><MudSkeleton SkeletonType="SkeletonType.Text" Width="30px" Height="16px" /></div>
                        <div style="flex: 2;"><MudSkeleton SkeletonType="SkeletonType.Text" Width="160px" Height="16px" /></div>
                        <div style="flex: 2;"><MudSkeleton SkeletonType="SkeletonType.Text" Width="180px" Height="16px" /></div>
                        <div style="flex: 2;"><MudSkeleton SkeletonType="SkeletonType.Text" Width="140px" Height="16px" /></div>
                        <div style="flex: 1; text-align: right;">
                            <div class="d-flex justify-end gap-2">
                                <MudSkeleton SkeletonType="SkeletonType.Circle" Width="28px" Height="28px" />
                                <MudSkeleton SkeletonType="SkeletonType.Circle" Width="28px" Height="28px" />
                            </div>
                        </div>
                    </div>

                    <div class="d-flex flex-column py-3 px-4 mobile-skeleton gap-2" style="border-bottom: 1px solid var(--border-color);">
                        <div class="d-flex justify-space-between align-center">
                            <MudSkeleton SkeletonType="SkeletonType.Text" Width="40%" Height="16px" />
                            <MudSkeleton SkeletonType="SkeletonType.Text" Width="20%" Height="14px" />
                        </div>
                        <MudSkeleton SkeletonType="SkeletonType.Text" Width="60%" Height="14px" />
                        <div class="d-flex justify-space-between align-center mt-1">
                            <MudSkeleton SkeletonType="SkeletonType.Text" Width="40%" Height="14px" />
                            <div class="d-flex gap-2">
                                <MudSkeleton SkeletonType="SkeletonType.Circle" Width="28px" Height="28px" />
                                <MudSkeleton SkeletonType="SkeletonType.Circle" Width="28px" Height="28px" />
                            </div>
                        </div>
                    </div>
                }

                <div class="d-flex justify-end pa-4">
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="100%" Style="max-width: 250px;" Height="32px" Class="rounded-md" />
                </div>
            </MudCardContent>
        </MudCard>
    }
    else
    {
        <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pt-4" Class="shadcn-tabs">

            <MudTabPanel Text="Active Vendors" OnClick="@(() => LoadList(false))">
                <MudCard Elevation="0" Outlined="true" Class="shadcn-card">
                    <MudTable Items="@vendors" Dense="true" Hover="true" Elevation="0" Filter="new Func<VendorDTO, bool>(FilterFunc)" Loading="@_loading" Class="shadcn-table" Breakpoint="Breakpoint.Sm">
                        <ToolBarContent>
                            <div style="font-size: 1.125rem; font-weight: 600; color: var(--text-main);">Active List</div>
                            <MudSpacer />
                            <MudTextField @bind-Value="searchString"
                                          Placeholder="Search vendors..."
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Outlined.Search"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="shadcn-input"
                                          Style="max-width: 300px; margin-top: 0;"></MudTextField>
                        </ToolBarContent>
                        <HeaderContent>
                            <MudTh>ID</MudTh>
                            <MudTh>Name</MudTh>
                            <MudTh>Email</MudTh>
                            <MudTh>Contact Person</MudTh>
                            <MudTh Style="text-align:right">Actions</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="ID" Style="color: var(--text-muted);">@context.Id</MudTd>
                            <MudTd DataLabel="Name" Style="font-weight: 500; color: var(--text-main);">@context.Name</MudTd>
                            <MudTd DataLabel="Email" Style="color: var(--text-muted);">@context.Email</MudTd>
                            <MudTd DataLabel="Contact" Style="color: var(--text-muted);">@context.ContactPerson</MudTd>
                            <MudTd DataLabel="Actions" Style="text-align:right">
                                <MudIconButton Icon="@Icons.Material.Outlined.Edit"
                                               Size="Size.Small"
                                               Class="shadcn-icon-btn mr-1"
                                               OnClick="() => OpenEditDialog(context)" />
                                <MudIconButton Icon="@Icons.Material.Outlined.Archive"
                                               Size="Size.Small"
                                               Class="shadcn-icon-btn text-destructive"
                                               OnClick="() => ConfirmDelete(context.Id)" />
                            </MudTd>
                        </RowTemplate>
                        <PagerContent><MudTablePager /></PagerContent>
                    </MudTable>
                </MudCard>
            </MudTabPanel>

            <MudTabPanel Text="Archived Vendors" OnClick="@(() => LoadList(true))">
                <MudCard Elevation="0" Outlined="true" Class="shadcn-card">
                    <MudTable Items="@vendors" Dense="true" Hover="true" Elevation="0" Filter="new Func<VendorDTO, bool>(FilterFunc)" Loading="@_loading" Class="shadcn-table" Breakpoint="Breakpoint.Sm">
                        <ToolBarContent>
                            <div style="font-size: 1.125rem; font-weight: 600; color: var(--text-main);">Archived List</div>
                            <MudSpacer />
                            <MudTextField @bind-Value="searchString"
                                          Placeholder="Search archived..."
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Outlined.Search"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="shadcn-input"
                                          Style="max-width: 300px; margin-top: 0;"></MudTextField>
                        </ToolBarContent>
                        <HeaderContent>
                            <MudTh>ID</MudTh>
                            <MudTh>Name</MudTh>
                            <MudTh>Email</MudTh>
                            <MudTh Style="text-align:right">Actions</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="ID" Style="color: var(--text-muted);">@context.Id</MudTd>
                            <MudTd DataLabel="Name" Style="color: var(--text-muted); text-decoration: line-through;">@context.Name</MudTd>
                            <MudTd DataLabel="Email" Style="color: var(--text-muted);">@context.Email</MudTd>
                            <MudTd DataLabel="Actions" Style="text-align:right">
                                <MudTooltip Text="Restore Vendor">
                                    <MudIconButton Icon="@Icons.Material.Outlined.RestoreFromTrash"
                                                   Size="Size.Small"
                                                   Class="shadcn-icon-btn text-success"
                                                   OnClick="() => ConfirmRestore(context.Id)" />
                                </MudTooltip>
                            </MudTd>
                        </RowTemplate>
                        <PagerContent><MudTablePager /></PagerContent>
                    </MudTable>
                </MudCard>
            </MudTabPanel>
        </MudTabs>
    }
</MudContainer>

@code {
    private List<VendorDTO> vendors = new List<VendorDTO>();
    private string searchString = "";
    private bool _loading = true;
    private bool _initialLoading = true;
    private bool _showArchived = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadList(false);
        _initialLoading = false;
        StateHasChanged();
    }

    private async Task LoadList(bool archived)
    {
        _showArchived = archived;
        _loading = true;
        try
        {
            var all = await PayableService.GetVendorsAsync(archived);
            if (archived)
                vendors = all?.Where(v => v.IsDeleted).ToList() ?? new List<VendorDTO>();
            else
                vendors = all ?? new List<VendorDTO>();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load vendors.");
            Snackbar.Add("Failed to load vendors. Please try again.", Severity.Error);
        }
        finally { _loading = false; }
    }

    private bool FilterFunc(VendorDTO element)
    {
        if (string.IsNullOrWhiteSpace(searchString)) return true;
        if (element.Name.Contains(searchString, StringComparison.OrdinalIgnoreCase)) return true;
        if (element.ContactPerson?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true) return true;
        return false;
    }

    private async Task OpenAddDialog()
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<VendorDialog>("Add Vendor", options);
        var result = await dialog.Result;
        if (result != null && !result.Canceled) await LoadList(false);
    }

    private async Task OpenEditDialog(VendorDTO vendor)
    {
        var parameters = new DialogParameters { ["Vendor"] = vendor };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<VendorDialog>("Edit Vendor", parameters, options);
        var result = await dialog.Result;
        if (result != null && !result.Canceled) await LoadList(false);
    }

    private async Task ConfirmDelete(int id)
    {
        bool result = await ShowConfirmDialog(
            "Archive this vendor?",
            "Archived vendors are hidden from active vendor lists.",
            "Archive",
            Color.Error);
        if (result == true)
        {
            try
            {
                await PayableService.DeleteVendorAsync(id);
                Snackbar.Add("Vendor archived.", Severity.Success);
                await LoadList(false);
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Failed to archive vendor with id {VendorId}.", id);
                Snackbar.Add("Unable to archive vendor. Please try again.", Severity.Error);
            }
        }
    }

    private async Task ConfirmRestore(int id)
    {
        bool result = await ShowConfirmDialog(
            "Restore this vendor?",
            "This vendor will return to active vendor lists.",
            "Restore",
            Color.Success);
        if (result == true)
        {
            try
            {
                await PayableService.RestoreVendorAsync(id);
                Snackbar.Add("Vendor restored.", Severity.Success);
                await LoadList(true);
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Failed to restore vendor with id {VendorId}.", id);
                Snackbar.Add("Unable to restore vendor. Please try again.", Severity.Error);
            }
        }
    }

    private async Task<bool> ShowConfirmDialog(string content, string subText, string buttonText, Color color)
    {
        var parameters = new DialogParameters
        {
            [nameof(ShadcnConfirmDialog.ContentText)] = content,
            [nameof(ShadcnConfirmDialog.SubText)] = subText,
            [nameof(ShadcnConfirmDialog.ButtonText)] = buttonText,
            [nameof(ShadcnConfirmDialog.Color)] = color
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ShadcnConfirmDialog>("Confirm", parameters, options);
        var result = await dialog.Result;
        return result is not null && !result.Canceled;
    }
}
