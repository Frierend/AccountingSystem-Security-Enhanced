    private void OpenSensitiveAction(string action)
    {
        sensitiveAction = action;
        mfaReauthenticationModel = new MfaReauthenticationDTO();
    }

    private void CancelSensitiveAction()
    {
        sensitiveAction = null;
        mfaReauthenticationModel = new MfaReauthenticationDTO();
    }

    private async Task HandleSensitiveActionAsync()
    {
        if (string.IsNullOrWhiteSpace(sensitiveAction))
        {
            return;
        }

        isSensitiveActionSubmitting = true;
        try
        {
            switch (sensitiveAction)
            {
                case ResetAction:
                    latestRecoveryCodes.Clear();
                    mfaSetup = await AuthService.ResetAuthenticator(mfaReauthenticationModel);
                    Snackbar.Add("Authenticator reset. Scan the new QR code and verify it to re-enable MFA.", Severity.Info);
                    break;
                case RegenerateAction:
                    latestRecoveryCodes = (await AuthService.RegenerateRecoveryCodes(mfaReauthenticationModel)).RecoveryCodes;
                    Snackbar.Add("Recovery codes regenerated successfully.", Severity.Success);
                    break;
                case DisableAction:
                    await AuthService.DisableMfa(mfaReauthenticationModel);
                    latestRecoveryCodes.Clear();
                    mfaSetup = null;
                    Snackbar.Add("Authenticator App MFA has been disabled.", Severity.Success);
                    break;
            }

            await LoadMfaStatusAsync();
            CancelSensitiveAction();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to execute MFA sensitive action {Action}.", sensitiveAction);
            Snackbar.Add(
                string.IsNullOrWhiteSpace(ex.Message)
                    ? "Unable to complete the MFA action. Please try again."
                    : ex.Message,
                Severity.Error);
        }
        finally
        {
            isSensitiveActionSubmitting = false;
        }
    }

    private string GetSensitiveActionTitle() => sensitiveAction switch
    {
        ResetAction => "Reset authenticator app",
        RegenerateAction => "Regenerate recovery codes",
        DisableAction => "Disable authenticator app MFA",
        _ => "Confirm action"
    };

    private string GetSensitiveActionButtonText() => sensitiveAction switch
    {
        ResetAction => "Reset Authenticator",
        RegenerateAction => "Regenerate Codes",
        DisableAction => "Disable Authenticator",
        _ => "Confirm"
    };

    private Color GetSensitiveActionColor() => sensitiveAction switch
    {
        ResetAction => Color.Warning,
        RegenerateAction => Color.Primary,
        DisableAction => Color.Error,
        _ => Color.Primary
    };
}
