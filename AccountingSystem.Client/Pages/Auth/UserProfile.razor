@page "/profile"
@using AccountingSystem.Shared.DTOs
@using AccountingSystem.Shared.Validation
@using AccountingSystem.Client.Services
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject AuthService AuthService
@inject ISnackbar Snackbar
@inject ILogger<UserProfile> Logger

<PageTitle>Profile - AccSys</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6 mb-10">
    <div class="mb-6">
        <h2 style="font-size: 1.5rem; font-weight: 600; letter-spacing: -0.025em; color: var(--text-main); margin: 0;">
            My Account Settings
        </h2>
        <p style="color: var(--text-muted); font-size: 0.875rem; margin: 0.25rem 0 0 0;">
            Manage your personal profile and security preferences.
        </p>
    </div>

    <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pt-4" Class="shadcn-tabs">
        <MudTabPanel Text="General Information" Icon="@Icons.Material.Outlined.Person">
            <EditForm Model="@profileModel" OnValidSubmit="HandleUpdateProfile">
                <DataAnnotationsValidator />
                <MudCard Elevation="0" Outlined="true" Class="shadcn-card">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <div style="font-size: 1.125rem; font-weight: 600; color: var(--text-main);">Profile Details</div>
                            <div style="font-size: 0.875rem; color: var(--text-muted);">Update your personal information and email address.</div>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudGrid Spacing="3">
                            <MudItem xs="12" sm="6">
                                <MudTextField Label="Full Name"
                                              @bind-Value="profileModel.FullName"
                                              For="@(() => profileModel.FullName)"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              Class="shadcn-input" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Label="Email Address"
                                              @bind-Value="profileModel.Email"
                                              For="@(() => profileModel.Email)"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              Class="shadcn-input" />
                            </MudItem>
                        </MudGrid>
                    </MudCardContent>

                    <MudCardActions Class="d-flex justify-end pa-4">
                        <MudButton ButtonType="ButtonType.Submit"
                                   Variant="Variant.Filled"
                                   Class="save-btn"
                                   Size="Size.Medium"
                                   Disabled="@isProfileSubmitting">
                            @(isProfileSubmitting ? "Saving..." : "Save Changes")
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </EditForm>
        </MudTabPanel>

        <MudTabPanel Text="Security" Icon="@Icons.Material.Outlined.Lock">
            <EditForm Model="@passwordModel" OnValidSubmit="HandleChangePassword">
                <DataAnnotationsValidator />
                <MudCard Elevation="0" Outlined="true" Class="shadcn-card mb-6">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <div style="font-size: 1.125rem; font-weight: 600; color: var(--text-main);">Change Password</div>
                            <div style="font-size: 0.875rem; color: var(--text-muted);">Ensure your account is using a long, random password to stay secure.</div>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudGrid Spacing="3">
                            <MudItem xs="12">
                                <MudTextField Label="Current Password"
                                              @bind-Value="passwordModel.CurrentPassword"
                                              For="@(() => passwordModel.CurrentPassword)"
                                              InputType="InputType.Password"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              Class="shadcn-input" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Label="New Password"
                                              @bind-Value="passwordModel.NewPassword"
                                              For="@(() => passwordModel.NewPassword)"
                                              InputType="InputType.Password"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              Class="shadcn-input"
                                              HelperText="@PasswordPolicy.Description" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Label="Confirm New Password"
                                              @bind-Value="passwordModel.ConfirmPassword"
                                              For="@(() => passwordModel.ConfirmPassword)"
                                              InputType="InputType.Password"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              Class="shadcn-input" />
                            </MudItem>
                        </MudGrid>
                    </MudCardContent>

                    <MudCardActions Class="d-flex justify-end pa-4">
                        <MudButton ButtonType="ButtonType.Submit"
                                   Variant="Variant.Filled"
                                   Class="custom-button"
                                   Size="Size.Medium"
                                   Disabled="@isPasswordSubmitting">
                            @(isPasswordSubmitting ? "Updating..." : "Update Password")
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </EditForm>

            <MudCard Elevation="0" Outlined="true" Class="shadcn-card mb-6">
                <MudCardHeader>
                    <CardHeaderContent>
                        <div style="font-size: 1.125rem; font-weight: 600; color: var(--text-main);">Authenticator App MFA</div>
                        <div style="font-size: 0.875rem; color: var(--text-muted);">Scan with Google Authenticator to add a second factor to your sign-in.</div>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    @if (isMfaLoading)
                    {
                        <div class="d-flex justify-center py-8">
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                        </div>
                    }
                    else
                    {
                            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
                                Authenticator App MFA uses Google Authenticator-compatible TOTP codes. Email OTP MFA can be managed separately below.
                            </MudAlert>

                        <div class="d-flex flex-wrap gap-3 align-center mb-4">
                            <MudChip T="string"
                                     Color="@(mfaStatus.IsAuthenticatorAppEnabled ? Color.Success : Color.Default)"
                                     Variant="Variant.Filled">
                                @(mfaStatus.IsAuthenticatorAppEnabled ? "Authenticator App Enabled" : "Authenticator App Not Enabled")
                            </MudChip>
                            <MudChip T="string"
                                     Color="@(mfaStatus.IsTwoFactorEnabled ? Color.Success : Color.Default)"
                                     Variant="Variant.Outlined">
                                @(mfaStatus.IsTwoFactorEnabled ? "MFA Enabled" : "MFA Not Enabled")
                            </MudChip>
                            <MudChip T="string" Variant="Variant.Outlined" Color="Color.Primary">
                                Recovery codes left: @mfaStatus.RecoveryCodesLeft
                            </MudChip>
                        </div>

                        @if (latestRecoveryCodes.Count > 0)
                        {
                            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-4">
                                Save these recovery codes now. They are shown only once and each code works a single time.
                            </MudAlert>

                            <MudPaper Outlined="true" Class="pa-4 mb-4" Style="background: var(--bg-background);">
                                <div class="recovery-grid">
                                    @foreach (var recoveryCode in latestRecoveryCodes)
                                    {
                                        <div class="recovery-code">@recoveryCode</div>
                                    }
                                </div>
                            </MudPaper>
                        }

                        @if (mfaSetup is not null)
                        {
                            <MudDivider Class="my-4" />
                            <MudText Typo="Typo.subtitle1" Class="mb-2">Scan with Google Authenticator</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                                If you can’t scan the QR code, enter the manual key instead.
                            </MudText>

                            <div class="d-flex justify-center mb-4">
                                <MfaQrCode Value="@mfaSetup.AuthenticatorUri" />
                            </div>

                            <MudTextField Label="Manual key"
                                          Value="@mfaSetup.SharedKey"
                                          ReadOnly="true"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="shadcn-input mb-4" />

                            <EditForm Model="@mfaVerificationModel" OnValidSubmit="HandleVerifyMfaSetup">
                                <DataAnnotationsValidator />
                                <MudTextField Label="6-digit code"
                                              @bind-Value="mfaVerificationModel.Code"
                                              For="@(() => mfaVerificationModel.Code)"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              Class="shadcn-input mb-4"
                                              MaxLength="6" />

                                <div class="d-flex flex-wrap gap-3 justify-end">
                                    <MudButton Variant="Variant.Text"
                                               Color="Color.Secondary"
                                               Disabled="@isMfaSubmitting"
                                               OnClick="CancelMfaSetup">
                                        Cancel
                                    </MudButton>
                                    <MudButton ButtonType="ButtonType.Submit"
                                               Variant="Variant.Filled"
                                               Color="Color.Primary"
                                               Disabled="@isMfaSubmitting">
                                        @(isMfaSubmitting ? "Verifying..." : "Enable Authenticator")
                                    </MudButton>
                                </div>
                            </EditForm>
                        }
                        else
                        {
                            <div class="d-flex flex-wrap gap-3">
                                @if (!mfaStatus.IsAuthenticatorAppEnabled)
                                {
                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Primary"
                                               Disabled="@isMfaSubmitting"
                                               OnClick="HandleBeginMfaSetup">
                                        Set Up Authenticator
                                    </MudButton>
                                }
                                else
                                {
                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Primary"
                                               Disabled="@isSensitiveActionSubmitting"
                                               OnClick="@(() => OpenSensitiveAction("regenerate"))">
                                        Regenerate Recovery Codes
                                    </MudButton>
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Warning"
                                               Disabled="@isSensitiveActionSubmitting"
                                               OnClick="@(() => OpenSensitiveAction("reset"))">
                                        Reset Authenticator
                                    </MudButton>
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Error"
                                               Disabled="@isSensitiveActionSubmitting"
                                               OnClick="@(() => OpenSensitiveAction("disable"))">
                                        Disable Authenticator
                                    </MudButton>
                                }
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(sensitiveAction))
                        {
                            <MudPaper Outlined="true" Class="pa-4 mt-5" Style="background: var(--bg-background);">
                                <MudText Typo="Typo.subtitle1" Class="mb-2">@GetSensitiveActionTitle()</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                                    Confirm this action with exactly one method: your current password, a Google Authenticator code, or a recovery code.
                                </MudText>

                                <EditForm Model="@mfaReauthenticationModel" OnValidSubmit="HandleSensitiveActionAsync">
                                    <DataAnnotationsValidator />
                                    <MudGrid Spacing="3">
                                        <MudItem xs="12" sm="4">
                                            <MudTextField Label="Current password"
                                                          @bind-Value="mfaReauthenticationModel.CurrentPassword"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense"
                                                          InputType="InputType.Password"
                                                          Class="shadcn-input" />
                                        </MudItem>
                                        <MudItem xs="12" sm="4">
                                            <MudTextField Label="Authenticator code"
                                                          @bind-Value="mfaReauthenticationModel.TwoFactorCode"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense"
                                                          Class="shadcn-input"
                                                          MaxLength="6" />
                                        </MudItem>
                                        <MudItem xs="12" sm="4">
                                            <MudTextField Label="Recovery code"
                                                          @bind-Value="mfaReauthenticationModel.RecoveryCode"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense"
                                                          Class="shadcn-input" />
                                        </MudItem>
                                    </MudGrid>

                                    <div class="d-flex flex-wrap gap-3 justify-end mt-4">
                                        <MudButton Variant="Variant.Text"
                                                   Color="Color.Secondary"
                                                   Disabled="@isSensitiveActionSubmitting"
                                                   OnClick="CancelSensitiveAction">
                                            Cancel
                                        </MudButton>
                                        <MudButton ButtonType="ButtonType.Submit"
                                                   Variant="Variant.Filled"
                                                   Color="@GetSensitiveActionColor()"
                                                   Disabled="@isSensitiveActionSubmitting">
                                            @(isSensitiveActionSubmitting ? "Working..." : GetSensitiveActionButtonText())
                                        </MudButton>
                                    </div>
                                </EditForm>
                            </MudPaper>
                        }
                    }
                </MudCardContent>
            </MudCard>

            <MudCard Elevation="0" Outlined="true" Class="shadcn-card">
                <MudCardHeader>
                    <CardHeaderContent>
                        <div style="font-size: 1.125rem; font-weight: 600; color: var(--text-main);">Email OTP MFA</div>
                        <div style="font-size: 0.875rem; color: var(--text-muted);">Send a one-time 6-digit code to your confirmed email address during sign-in.</div>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    @if (isMfaLoading)
                    {
                        <div class="d-flex justify-center py-8">
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                        </div>
                    }
                    else
                    {
                        <div class="d-flex flex-wrap gap-3 align-center mb-4">
                            <MudChip T="string"
                                     Color="@(mfaStatus.IsEmailOtpEnabled ? Color.Success : Color.Default)"
                                     Variant="Variant.Filled">
                                @(mfaStatus.IsEmailOtpEnabled ? "Email OTP Enabled" : "Email OTP Not Enabled")
                            </MudChip>
                            <MudChip T="string"
                                     Color="@(mfaStatus.IsEmailConfirmed ? Color.Success : Color.Warning)"
                                     Variant="Variant.Outlined">
                                @(mfaStatus.IsEmailConfirmed ? "Email Confirmed" : "Email Not Confirmed")
                            </MudChip>
                        </div>

                        @if (!mfaStatus.IsEmailConfirmed)
                        {
                            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-4">
                                <div class="d-flex flex-column flex-sm-row align-start align-sm-center justify-space-between gap-3">
                                    <span>Confirm your email address before enabling Email OTP MFA.</span>
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Warning"
                                               Size="Size.Small"
                                               Disabled="@(isEmailOtpSubmitting || isConfirmationSubmitting)"
                                               OnClick="HandleResendConfirmationAsync">
                                        @(isConfirmationSubmitting ? "Sending..." : "Resend confirmation email")
                                    </MudButton>
                                </div>
                            </MudAlert>
                        }

                        @if (emailOtpSetupPending)
                        {
                            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
                                Enter the code sent to @mfaStatus.Email. Codes expire after a few minutes and can be used only once.
                            </MudAlert>

                            <EditForm Model="@emailOtpVerificationModel" OnValidSubmit="HandleVerifyEmailOtpSetup">
                                <DataAnnotationsValidator />
                                <MudTextField Label="Email code"
                                              @bind-Value="emailOtpVerificationModel.Code"
                                              For="@(() => emailOtpVerificationModel.Code)"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              Class="shadcn-input mb-4"
                                              MaxLength="6" />

                                <div class="d-flex flex-wrap gap-3 justify-end">
                                    <MudButton Variant="Variant.Text"
                                               Color="Color.Secondary"
                                               Disabled="@isEmailOtpSubmitting"
                                               OnClick="CancelEmailOtpSetup">
                                        Cancel
                                    </MudButton>
                                    <MudButton ButtonType="ButtonType.Submit"
                                               Variant="Variant.Filled"
                                               Color="Color.Primary"
                                               Disabled="@isEmailOtpSubmitting">
                                        @(isEmailOtpSubmitting ? "Verifying..." : "Enable Email OTP")
                                    </MudButton>
                                </div>
                            </EditForm>
                        }
                        else if (!mfaStatus.IsEmailOtpEnabled)
                        {
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Disabled="@(isEmailOtpSubmitting || !mfaStatus.IsEmailConfirmed)"
                                       OnClick="HandleBeginEmailOtpSetup">
                                Send Setup Code
                            </MudButton>
                        }
                        else
                        {
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Error"
                                       Disabled="@isEmailOtpSubmitting"
                                       OnClick="OpenEmailOtpDisable">
                                Disable Email OTP
                            </MudButton>
                        }

                        @if (emailOtpDisableOpen)
                        {
                            <MudPaper Outlined="true" Class="pa-4 mt-5" Style="background: var(--bg-background);">
                                <MudText Typo="Typo.subtitle1" Class="mb-2">Disable Email OTP MFA</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                                    Confirm with your current password. If Authenticator App MFA is enabled, an authenticator code or recovery code can also be used.
                                </MudText>

                                <EditForm Model="@emailOtpDisableModel" OnValidSubmit="HandleDisableEmailOtpAsync">
                                    <DataAnnotationsValidator />
                                    <MudGrid Spacing="3">
                                        <MudItem xs="12" sm="4">
                                            <MudTextField Label="Current password"
                                                          @bind-Value="emailOtpDisableModel.CurrentPassword"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense"
                                                          InputType="InputType.Password"
                                                          Class="shadcn-input" />
                                        </MudItem>
                                        <MudItem xs="12" sm="4">
                                            <MudTextField Label="Authenticator code"
                                                          @bind-Value="emailOtpDisableModel.TwoFactorCode"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense"
                                                          Class="shadcn-input"
                                                          MaxLength="6" />
                                        </MudItem>
                                        <MudItem xs="12" sm="4">
                                            <MudTextField Label="Recovery code"
                                                          @bind-Value="emailOtpDisableModel.RecoveryCode"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense"
                                                          Class="shadcn-input" />
                                        </MudItem>
                                    </MudGrid>

                                    <div class="d-flex flex-wrap gap-3 justify-end mt-4">
                                        <MudButton Variant="Variant.Text"
                                                   Color="Color.Secondary"
                                                   Disabled="@isEmailOtpSubmitting"
                                                   OnClick="CancelEmailOtpDisable">
                                            Cancel
                                        </MudButton>
                                        <MudButton ButtonType="ButtonType.Submit"
                                                   Variant="Variant.Filled"
                                                   Color="Color.Error"
                                                   Disabled="@isEmailOtpSubmitting">
                                            @(isEmailOtpSubmitting ? "Working..." : "Disable Email OTP")
                                        </MudButton>
                                    </div>
                                </EditForm>
                            </MudPaper>
                        }
                    }
                </MudCardContent>
            </MudCard>
        </MudTabPanel>
    </MudTabs>
</MudContainer>

<style>
    .recovery-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 0.75rem;
    }

    .recovery-code {
        font-family: "Courier New", monospace;
        font-size: 0.95rem;
        font-weight: 600;
        padding: 0.75rem;
        border: 1px solid var(--border-color);
        border-radius: var(--radius-md);
        background: var(--bg-surface);
        text-align: center;
    }
</style>

@code {
    private const string ResetAction = "reset";
    private const string RegenerateAction = "regenerate";
    private const string DisableAction = "disable";

    private UpdateProfileDTO profileModel = new();
    private ChangePasswordDTO passwordModel = new();
    private VerifyAuthenticatorSetupDTO mfaVerificationModel = new();
    private VerifyEmailOtpMfaDTO emailOtpVerificationModel = new();
    private MfaReauthenticationDTO mfaReauthenticationModel = new();
    private MfaReauthenticationDTO emailOtpDisableModel = new();
    private MfaStatusDTO mfaStatus = new();
    private MfaSetupDTO? mfaSetup;
    private List<string> latestRecoveryCodes = new();
    private bool isProfileSubmitting;
    private bool isPasswordSubmitting;
    private bool isMfaLoading = true;
    private bool isMfaSubmitting;
    private bool isSensitiveActionSubmitting;
    private bool isEmailOtpSubmitting;
    private bool isConfirmationSubmitting;
    private string currentEmail = string.Empty;
    private string? sensitiveAction;
    private bool emailOtpSetupPending;
    private bool emailOtpDisableOpen;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var profile = await AuthService.GetCurrentProfile();
            profileModel.Email = profile.Email;
            profileModel.FullName = profile.FullName;
            currentEmail = profile.Email;
            await LoadMfaStatusAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load current profile.");
            Snackbar.Add("Unable to load account details. Please refresh and try again.", Severity.Error);
        }
    }

    private async Task LoadMfaStatusAsync()
    {
        isMfaLoading = true;
        try
        {
            mfaStatus = await AuthService.GetMfaStatus();
        }
        finally
        {
            isMfaLoading = false;
        }
    }

    private async Task HandleUpdateProfile()
    {
        isProfileSubmitting = true;
        var emailChanged = !string.Equals(currentEmail, profileModel.Email, StringComparison.OrdinalIgnoreCase);
        try
        {
            await AuthService.UpdateProfile(profileModel);
            var refreshedProfile = await AuthService.GetCurrentProfile();
            profileModel.Email = refreshedProfile.Email;
            profileModel.FullName = refreshedProfile.FullName;
            currentEmail = refreshedProfile.Email;
            await LoadMfaStatusAsync();
            var successMessage = emailChanged
                ? "Profile updated successfully. Please confirm your new email address before your next sign in."
                : "Profile updated successfully.";
            Snackbar.Add(successMessage, Severity.Success);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to update user profile.");
            Snackbar.Add(
                string.IsNullOrWhiteSpace(ex.Message)
                    ? "Unable to update profile. Please try again."
                    : ex.Message,
                Severity.Error);
        }
        finally
        {
            isProfileSubmitting = false;
        }
    }

    private async Task HandleChangePassword()
    {
        isPasswordSubmitting = true;
        try
        {
            await AuthService.ChangePassword(passwordModel);
            Snackbar.Add("Password changed successfully.", Severity.Success);
            passwordModel = new ChangePasswordDTO();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to change user password.");
            Snackbar.Add(
                string.IsNullOrWhiteSpace(ex.Message)
                    ? "Unable to change password. Please try again."
                    : ex.Message,
                Severity.Error);
        }
        finally
        {
            isPasswordSubmitting = false;
        }
    }

    private async Task HandleBeginMfaSetup()
    {
        isMfaSubmitting = true;
        try
        {
            latestRecoveryCodes.Clear();
            mfaSetup = await AuthService.BeginAuthenticatorSetup();
            mfaVerificationModel = new VerifyAuthenticatorSetupDTO();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to begin MFA setup.");
            Snackbar.Add(
                string.IsNullOrWhiteSpace(ex.Message)
                    ? "Unable to start MFA setup. Please try again."
                    : ex.Message,
                Severity.Error);
        }
        finally
        {
            isMfaSubmitting = false;
        }
    }

    private async Task HandleVerifyMfaSetup()
    {
        isMfaSubmitting = true;
        try
        {
            var recoveryCodes = await AuthService.VerifyAuthenticatorSetup(mfaVerificationModel);
            latestRecoveryCodes = recoveryCodes.RecoveryCodes;
            mfaSetup = null;
            mfaVerificationModel = new VerifyAuthenticatorSetupDTO();
            await LoadMfaStatusAsync();
            Snackbar.Add("Authenticator App MFA is now enabled.", Severity.Success);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to verify MFA setup.");
            Snackbar.Add(
                string.IsNullOrWhiteSpace(ex.Message)
                    ? "Unable to verify the authenticator code. Please try again."
                    : ex.Message,
                Severity.Error);
        }
        finally
        {
            isMfaSubmitting = false;
        }
    }

    private void CancelMfaSetup()
    {
        mfaSetup = null;
        mfaVerificationModel = new VerifyAuthenticatorSetupDTO();
    }

    private async Task HandleResendConfirmationAsync()
    {
        isConfirmationSubmitting = true;
        try
        {
            await AuthService.ResendConfirmation(new ResendConfirmationDTO { Email = mfaStatus.Email });
            Snackbar.Add("If your email still needs confirmation, a new confirmation link has been sent.", Severity.Info);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to resend profile email confirmation.");
            Snackbar.Add(
                string.IsNullOrWhiteSpace(ex.Message)
                    ? "Unable to resend confirmation email. Please try again."
                    : ex.Message,
                Severity.Error);
        }
        finally
        {
            isConfirmationSubmitting = false;
        }
    }

    private async Task HandleBeginEmailOtpSetup()
    {
        isEmailOtpSubmitting = true;
        try
        {
            await AuthService.SendEmailOtpSetupCode();
            emailOtpVerificationModel = new VerifyEmailOtpMfaDTO();
            emailOtpSetupPending = true;
            emailOtpDisableOpen = false;
            Snackbar.Add("Email verification code sent.", Severity.Info);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to begin Email OTP MFA setup.");
            Snackbar.Add(
                string.IsNullOrWhiteSpace(ex.Message)
                    ? "Unable to send an email verification code. Please try again."
                    : ex.Message,
                Severity.Error);
        }
        finally
        {
            isEmailOtpSubmitting = false;
        }
    }

    private async Task HandleVerifyEmailOtpSetup()
    {
        isEmailOtpSubmitting = true;
        try
        {
            await AuthService.VerifyEmailOtpSetup(emailOtpVerificationModel);
            emailOtpVerificationModel = new VerifyEmailOtpMfaDTO();
            emailOtpSetupPending = false;
            await LoadMfaStatusAsync();
            Snackbar.Add("Email OTP MFA is now enabled.", Severity.Success);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to verify Email OTP MFA setup.");
            Snackbar.Add(
                string.IsNullOrWhiteSpace(ex.Message)
                    ? "Unable to verify the email code. Please try again."
                    : ex.Message,
                Severity.Error);
        }
        finally
        {
            isEmailOtpSubmitting = false;
        }
    }

    private void CancelEmailOtpSetup()
    {
        emailOtpSetupPending = false;
        emailOtpVerificationModel = new VerifyEmailOtpMfaDTO();
    }

    private void OpenEmailOtpDisable()
