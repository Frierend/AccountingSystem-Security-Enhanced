@page "/reset-password"
@layout LoginLayout
@using AccountingSystem.Client.Services
@using AccountingSystem.Shared.DTOs
@using AccountingSystem.Shared.Validation
@using Microsoft.AspNetCore.Components
@using MudBlazor

@inject AuthService AuthService
@inject NavigationManager NavManager
@inject ISnackbar Snackbar
@inject ILogger<ResetPassword> Logger

<PageTitle>Reset Password - AccSys</PageTitle>

<div class="auth-page-wrapper">
    <div class="auth-card shadcn-card">
        
        <div class="auth-header">
            <div class="auth-icon-wrapper">
                <MudIcon Icon="@Icons.Material.Outlined.Key" Size="Size.Medium" Class="auth-icon" />
            </div>
            <h1 class="auth-title">Set new password</h1>
            <p class="auth-subtitle">
                Choose a strong password or passphrase to secure your account.
            </p>
        </div>

        <EditForm Model="@model" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label class="form-label">Email Address</label>
                <MudTextField @bind-Value="model.Email"
                              For="@(() => model.Email)"
                              Placeholder="name@example.com"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              DisableUnderLine="true"
                              Class="shadcn-input-auth" />
            </div>

            <div class="form-group">
                <label class="form-label">New Password</label>
                <MudTextField @bind-Value="model.NewPassword"
                              For="@(() => model.NewPassword)"
                              Placeholder="Enter new password"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              InputType="@passwordInputType"
                              Adornment="Adornment.End"
                              AdornmentIcon="@passwordInputIcon"
                              OnAdornmentClick="TogglePasswordVisibility"
                              AdornmentAriaLabel="Toggle password visibility"
                              DisableUnderLine="true"
                              Class="shadcn-input-auth" />
                <div class="form-helper mt-1">@PasswordPolicy.Description</div>
            </div>

            <div class="form-group">
                <label class="form-label">Confirm New Password</label>
                <MudTextField @bind-Value="model.ConfirmPassword"
                              For="@(() => model.ConfirmPassword)"
                              Placeholder="Confirm new password"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              InputType="@passwordInputType"
                              DisableUnderLine="true"
                              Class="shadcn-input-auth" />
            </div>

            @if (!string.IsNullOrWhiteSpace(statusMessage))
            {
                <div class="auth-alert @(statusSeverity == Severity.Success ? "alert-success" : "alert-error")">
                    <MudIcon Icon="@(statusSeverity == Severity.Success ? Icons.Material.Outlined.CheckCircle : Icons.Material.Outlined.ErrorOutline)" Size="Size.Small" />
                    <span>@statusMessage</span>
                </div>
            }

            <MudButton ButtonType="ButtonType.Submit"
                       Variant="Variant.Filled"
                       FullWidth="true"
                       Disabled="@(isSubmitting || string.IsNullOrWhiteSpace(model.Token))"
                       Class="shadcn-btn-primary mt-4">
                @if (isSubmitting)
                {
                    <MudProgressCircular Class="ms-n1 me-2" Size="Size.Small" Indeterminate="true" />
                    <span>Resetting...</span>
                }
                else
                {
                    <span>Reset Password</span>
                }
            </MudButton>
        </EditForm>

        <div class="auth-footer">
            <MudLink Href="/" Class="auth-link" Underline="Underline.Hover">
                <MudIcon Icon="@Icons.Material.Outlined.ArrowBack" Size="Size.Small" Class="mr-1" Style="font-size: 14px;" />
                Back to sign in
            </MudLink>
        </div>

    </div>
</div>

<style>
    /* Auth Page Layout */
    .auth-page-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: var(--bg-background);
        padding: 1rem;
    }

    .auth-card {
        width: 100%;
        max-width: 400px;
        padding: 2.5rem 2rem;
        background-color: var(--bg-surface);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-lg);
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -2px rgba(0, 0, 0, 0.05);
    }

    /* Header Styles */
    .auth-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .auth-icon-wrapper {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background-color: var(--bg-muted);
        margin-bottom: 1rem;
        border: 1px solid var(--border-color);
    }

    .auth-icon {
        color: var(--text-main);
    }

    .auth-title {
        font-size: 1.5rem;
        font-weight: 600;
        letter-spacing: -0.025em;
        color: var(--text-main);
        margin: 0 0 0.5rem 0;
    }

    .auth-subtitle {
        font-size: 0.875rem;
        color: var(--text-muted);
        margin: 0;
        line-height: 1.5;
    }

    /* Form Styles */
    .form-group {
        margin-bottom: 1.25rem;
    }

    .form-label {
        display: block;
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--text-main);
        margin-bottom: 0.5rem;
    }

    .form-helper {
        font-size: 0.75rem;
        color: var(--text-muted);
        line-height: 1.4;
    }

    /* Customizing MudBlazor input to look like Shadcn */
    .shadcn-input-auth {
        background-color: var(--bg-surface);
    }
    
        .shadcn-input-auth .mud-input-outlined-border {
            border-color: var(--border-color) !important;
            border-radius: var(--radius-md) !important;
        }

        .shadcn-input-auth.mud-input-outlined:focus-within .mud-input-outlined-border {
            border-color: var(--text-main) !important;
            border-width: 1px !important;
            box-shadow: 0 0 0 2px var(--bg-background), 0 0 0 4px var(--text-main) !important;
        }

    /* Alert Box */
    .auth-alert {
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
        padding: 0.75rem 1rem;
        border-radius: var(--radius-md);
        font-size: 0.875rem;
        font-weight: 500;
        margin-bottom: 1.5rem;
        line-height: 1.4;
    }

    .alert-success {
        background-color: rgba(22, 163, 74, 0.1);
        color: #16a34a;
        border: 1px solid rgba(22, 163, 74, 0.2);
    }

    .alert-error {
        background-color: rgba(220, 38, 38, 0.1);
        color: #dc2626;
        border: 1px solid rgba(220, 38, 38, 0.2);
    }

    /* Buttons & Links */
    .shadcn-btn-primary {
        border-radius: var(--radius-md) !important;
        text-transform: none !important;
        font-weight: 500 !important;
        background-color: var(--text-main) !important;
        color: var(--bg-surface) !important;
        box-shadow: none !important;
        padding: 8px 16px !important;
    }

        .shadcn-btn-primary:hover {
            opacity: 0.9;
        }

    .auth-footer {
        margin-top: 2rem;
        text-align: center;
    }

    .auth-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.875rem;
        color: var(--text-muted) !important;
        font-weight: 500;
        transition: color 0.2s ease;
    }

        .auth-link:hover {
            color: var(--text-main) !important;
        }
</style>

@code {
    [SupplyParameterFromQuery(Name = "email")]
    public string? Email { get; set; }

    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    private ResetPasswordDTO model = new();
    private bool isSubmitting;
    private string? statusMessage;
    private Severity statusSeverity = Severity.Info;

    // Password visibility state
    private bool isShowPassword = false;
    private InputType passwordInputType = InputType.Password;
    private string passwordInputIcon = Icons.Material.Outlined.VisibilityOff;

    protected override void OnParametersSet()
    {
        model.Email = Email ?? string.Empty;
        model.Token = Token ?? string.Empty;
    }

    private void TogglePasswordVisibility()
    {
        isShowPassword = !isShowPassword;
        passwordInputType = isShowPassword ? InputType.Text : InputType.Password;
        passwordInputIcon = isShowPassword ? Icons.Material.Outlined.Visibility : Icons.Material.Outlined.VisibilityOff;
    }

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        statusMessage = null;

        try
        {
            await AuthService.ResetPassword(model);
            statusMessage = "Password reset successfully. You can sign in with your new password now.";
            statusSeverity = Severity.Success;
            Snackbar.Add(statusMessage, Severity.Success);
            
            // Adding a small delay for better UX before navigation
            await Task.Delay(1000);
            NavManager.NavigateTo("/");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to reset password for {Email}.", model.Email);
            statusMessage = string.IsNullOrWhiteSpace(ex.Message)
                ? "Unable to reset password. Please try again."
                : ex.Message;
            statusSeverity = Severity.Error;
        }
        finally
        {
            isSubmitting = false;
        }
    }
}