@page "/payment-callback"
@using AccountingSystem.Shared.DTOs
@using AccountingSystem.Client.Services
@using AccountingSystem.Shared.Enums
@using MudBlazor
@using Blazored.LocalStorage
@inject ReceivableService ReceivableService
@inject NavigationManager NavManager
@inject ISnackbar Snackbar
@inject ILocalStorageService LocalStorage
@inject ILogger<PaymentCallback> Logger

<PageTitle>Payment Verification</PageTitle>

<div class="d-flex align-center justify-center" style="min-height: 80vh; padding: 1rem;">
    <MudCard Elevation="0" Outlined="true" Class="shadcn-card" Style="width: 100%; max-width: 400px; padding: 3rem 2rem;">
        <MudCardContent Class="text-center pa-0">

            @if (isVerifying)
            {
                <MudProgressCircular Color="Color.Default" Size="Size.Large" Indeterminate="true" Class="mb-6" Style="color: var(--text-muted);" />
                <div style="font-size: 1.5rem; font-weight: 600; letter-spacing: -0.025em; color: var(--text-main); margin-bottom: 0.5rem;">
                    Verifying Payment
                </div>
                <div style="font-size: 0.875rem; color: var(--text-muted);">
                    Please wait while we securely confirm your transaction with PayMongo.
                </div>
            }
            else if (isSuccess)
            {
                <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Style="font-size: 4rem; color: var(--color-success);" Class="mb-6" />
                <div style="font-size: 1.5rem; font-weight: 600; letter-spacing: -0.025em; color: var(--text-main); margin-bottom: 0.5rem;">
                    Payment Successful
                </div>
                <div style="font-size: 0.875rem; color: var(--text-muted); margin-bottom: 2rem;">
                    Your payment has been successfully verified and recorded in the ledger.
                </div>
                <MudButton Variant="Variant.Filled"
                           Class="custom-button"
                           Href="/ar"
                           FullWidth="true"
                           Size="Size.Large">
                    Return to Invoices
                </MudButton>
            }
            else
            {
                <MudIcon Icon="@Icons.Material.Outlined.ErrorOutline" Style="font-size: 4rem; color: var(--color-destructive);" Class="mb-6" />
                <div style="font-size: 1.5rem; font-weight: 600; letter-spacing: -0.025em; color: var(--text-main); margin-bottom: 0.5rem;">
                    Payment Failed
                </div>
                <div style="font-size: 0.875rem; color: var(--text-muted); margin-bottom: 2rem;">
                    @errorMessage
                </div>
                <MudButton Variant="Variant.Outlined"
                           Class="shadcn-btn-outline"
                           Href="/ar"
                           FullWidth="true"
                           Size="Size.Large">
                    Back to Invoices
                </MudButton>
            }

        </MudCardContent>
    </MudCard>
</div>

@code {
    [SupplyParameterFromQuery] public int InvoiceId { get; set; }
    [SupplyParameterFromQuery] public int AccountId { get; set; }
    [SupplyParameterFromQuery] public decimal Amount { get; set; }
    [SupplyParameterFromQuery(Name = "source_id")] public string? UrlSourceId { get; set; }

    private bool isVerifying = true;
    private bool isSuccess = false;
    private string errorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        string? sourceId = UrlSourceId;

        if (string.IsNullOrEmpty(sourceId))
        {
            sourceId = await LocalStorage.GetItemAsync<string>("pending_payment_source_id");
        }

        if (string.IsNullOrEmpty(sourceId))
        {
            isVerifying = false;
            errorMessage = "Lost payment reference. Please contact support.";
            return;
        }

        try
        {
            var paymentDto = new RecordPaymentDTO
            {
                ReferenceId = InvoiceId,
                AssetAccountId = AccountId,
                Amount = Amount,
                PaymentMethod = PaymentMethod.Online,
                PaymentDate = DateTime.Now,
                SourceId = sourceId,
                Remarks = "Online Payment verified via Callback"
            };

            await ReceivableService.ReceivePaymentAsync(paymentDto);
            await LocalStorage.RemoveItemAsync("pending_payment_source_id");
            isSuccess = true;
            Snackbar.Add("Payment Verified & Recorded!", Severity.Success);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Payment callback verification failed.");
            errorMessage = "Verification failed. Please try again or contact support.";
            Snackbar.Add(errorMessage, Severity.Error);
        }
        finally
        {
            isVerifying = false;
        }
    }
}
