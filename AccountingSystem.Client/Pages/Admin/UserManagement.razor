@page "/admin/users"
@using AccountingSystem.Client.Shared.Dialogs
@using AccountingSystem.Shared.DTOs
@using AccountingSystem.Shared.Validation
@using AccountingSystem.Client.Services
@using Microsoft.AspNetCore.Authorization
@using MudBlazor
@attribute [Authorize(Roles = "Admin")]
@inject UserService UserService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ILogger<UserManagement> Logger

<PageTitle>User Management - AccSys</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6">
    <div class="d-flex justify-space-between align-center mb-6">
        <div>
            @if (_initialLoading)
            {
                <MudSkeleton SkeletonType="SkeletonType.Text" Width="200px" Height="32px" Class="mb-1" />
                <MudSkeleton SkeletonType="SkeletonType.Text" Width="300px" Height="16px" />
            }
            else
            {
                <h2 style="font-size: 1.5rem; font-weight: 600; letter-spacing: -0.025em; color: var(--text-main); margin: 0;">
                    User Management
                </h2>
                <p style="color: var(--text-muted); font-size: 0.875rem; margin: 0.25rem 0 0 0;">
                    Manage system access, user roles, and account permissions.
                </p>
            }
        </div>
    </div>

    <MudGrid>
        <MudItem xs="12" md="8">
            @if (_initialLoading)
            {
                <MudCard Elevation="0" Outlined="true" Class="shadcn-card">
                    <MudCardContent>
                        <div class="d-flex mb-4 gap-2">
                            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="100px" Height="32px" Style="border-radius: 6px;" />
                            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="120px" Height="32px" Style="border-radius: 6px;" />
                        </div>
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="100%" Height="300px" Style="border-radius: 6px;" />
                    </MudCardContent>
                </MudCard>
            }
            else
            {
                <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pt-4" Class="shadcn-tabs">
                    <MudTabPanel Text="Active Users" OnClick="@(() => LoadUsers(false))">
                        <MudCard Elevation="0" Outlined="true" Class="shadcn-card">
                            <MudTable Items="@users" Hover="true" Dense="true" Breakpoint="Breakpoint.Sm" Loading="@_loading" Elevation="0" Class="shadcn-table">
                                <HeaderContent>
                                    <MudTh>Email</MudTh>
                                    <MudTh>Full Name</MudTh>
                                    <MudTh>Role</MudTh>
                                    <MudTh Style="text-align:right">Actions</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="Email" Style="font-weight: 500; color: var(--text-main);">@context.Email</MudTd>
                                    <MudTd DataLabel="Full Name" Style="color: var(--text-muted);">@context.FullName</MudTd>
                                    <MudTd DataLabel="Role">
                                        <MudChip T="string" Size="Size.Small" Class="@(context.RoleName == "Admin" ? "shadcn-chip-destructive" : "shadcn-chip-default")">
                                            @context.RoleName
                                        </MudChip>
                                    </MudTd>
                                    <MudTd DataLabel="Actions" Style="text-align:right">
                                        @if (!string.IsNullOrEmpty(context.Email) && !context.Email.StartsWith("admin"))
                                        {
                                            <MudIconButton Icon="@Icons.Material.Outlined.Archive" Size="Size.Small" Class="shadcn-icon-btn text-destructive" OnClick="() => ConfirmDelete(context.Id)" />
                                        }
                                    </MudTd>
                                </RowTemplate>
                                <PagerContent><MudTablePager /></PagerContent>
                            </MudTable>
                        </MudCard>
                    </MudTabPanel>

                    <MudTabPanel Text="Archived" OnClick="@(() => LoadUsers(true))">
                        <MudCard Elevation="0" Outlined="true" Class="shadcn-card">
                            <MudTable Items="@users" Hover="true" Dense="true" Breakpoint="Breakpoint.Sm" Loading="@_loading" Elevation="0" Class="shadcn-table">
                                <HeaderContent>
                                    <MudTh>Email</MudTh>
                                    <MudTh>Role</MudTh>
                                    <MudTh Style="text-align:right">Actions</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="Email" Style="color: var(--text-muted); text-decoration: line-through;">@context.Email</MudTd>
                                    <MudTd DataLabel="Role">@context.RoleName</MudTd>
                                    <MudTd DataLabel="Actions" Style="text-align:right">
                                        <MudTooltip Text="Restore User">
                                            <MudIconButton Icon="@Icons.Material.Outlined.RestoreFromTrash" Size="Size.Small" Class="shadcn-icon-btn text-success" OnClick="() => ConfirmRestore(context.Id)" />
                                        </MudTooltip>
                                    </MudTd>
                                </RowTemplate>
                                <PagerContent><MudTablePager /></PagerContent>
                            </MudTable>
                        </MudCard>
                    </MudTabPanel>
                </MudTabs>
            }
        </MudItem>

        <MudItem xs="12" md="4">
            @if (_initialLoading)
            {
                <MudCard Elevation="0" Outlined="true" Class="shadcn-card">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudSkeleton SkeletonType="SkeletonType.Text" Width="120px" Height="24px" />
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        @for (int i = 0; i < 4; i++)
                        {
                            <div class="mb-4">
                                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="100%" Height="40px" Style="border-radius: 6px;" />
                            </div>
                        }
                    </MudCardContent>
                </MudCard>
            }
            else
            {
                <EditForm Model="@newUser" OnValidSubmit="HandleCreateUser">
                    <DataAnnotationsValidator />
                    <MudCard Elevation="0" Outlined="true" Class="shadcn-card">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <div style="font-size: 1rem; font-weight: 600; color: var(--text-main);">Create New User</div>
                                <div style="font-size: 0.75rem; color: var(--text-muted);">Add a new member to the system.</div>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            @if (isSubmitting)
                            {
                                @for (int i = 0; i < 4; i++)
                                {
                                    <div class="mb-4">
                                        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="100%" Height="40px" Style="border-radius: 6px;" />
                                    </div>
                                }
                            }
                            else
                            {
                                <MudTextField Label="Email" @bind-Value="newUser.Email" For="@(() => newUser.Email)" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-3 shadcn-input" />
                                <MudTextField Label="Full Name" @bind-Value="newUser.FullName" For="@(() => newUser.FullName)" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-3 shadcn-input" />
                                <MudSelect Label="Role" @bind-Value="newUser.RoleName" For="@(() => newUser.RoleName)" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter" Class="mb-3 shadcn-input">
                                    <MudSelectItem Value="@("Admin")" />
                                    <MudSelectItem Value="@("Accounting")" />
                                    <MudSelectItem Value="@("Management")" />
                                </MudSelect>
                                <MudTextField Label="Password" @bind-Value="newUser.Password" For="@(() => newUser.Password)" InputType="InputType.Password" Variant="Variant.Outlined" Margin="Margin.Dense" HelperText="@PasswordPolicy.Description" Class="mb-4 shadcn-input" />
                            }
                        </MudCardContent>
                        <MudCardActions Class="pb-4 px-4">
                            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Class="create-btn" Size="Size.Medium" FullWidth="true" Disabled="@isSubmitting">
                                @(isSubmitting ? "Creating..." : "Create Account")
                            </MudButton>
                        </MudCardActions>
                    </MudCard>
                </EditForm>
            }
        </MudItem>
    </MudGrid>
</MudContainer>

<style>
    .archive-hover:hover {
        color: #ff9800 !important;
        transform: scale(1.1);
        transition: all 0.2s ease-in-out;
    }

    .restore-hover:hover {
        color: #4caf50 !important;
        background-color: rgba(76, 175, 80, 0.1);
        border-radius: 50%;
        transform: scale(1.1);
        transition: all 0.2s ease-in-out;
    }
</style>

@code {
    private List<UserDTO> users = new List<UserDTO>();
    private RegisterDTO newUser = new RegisterDTO();
    private bool isSubmitting = false;
    private bool _loading = true;
    private bool _initialLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers(false);
        _initialLoading = false;
        StateHasChanged();
    }

    private async Task LoadUsers(bool archived)
    {
        _loading = true;
        try
        {
            var all = await UserService.GetAllUsersAsync(archived);
            if (archived)
                users = all?.Where(u => u.IsDeleted).ToList() ?? new List<UserDTO>();
            else
                users = all?.Where(u => !u.IsDeleted).ToList() ?? new List<UserDTO>();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load users.");
            Snackbar.Add("Failed to load users. Please try again.", Severity.Error);
        }
        finally { _loading = false; }
    }

    private async Task HandleCreateUser()
    {
        isSubmitting = true;
        try
        {
            await UserService.CreateUserAsync(newUser);
            Snackbar.Add("User created successfully.", Severity.Success);
            newUser = new RegisterDTO();
            await LoadUsers(false);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to create user.");
            Snackbar.Add(
                string.IsNullOrWhiteSpace(ex.Message)
                    ? "Unable to create user. Please try again."
                    : ex.Message,
                Severity.Error);
        }
        finally { isSubmitting = false; }
    }

    private async Task ConfirmDelete(int id)
    {
        var parameters = new DialogParameters<ShadcnConfirmDialog>
        {
            { x => x.ContentText, "Archive User?" },
            { x => x.SubText, "This user will lose system access immediately. You can restore them from the Archived tab." },
            { x => x.ButtonText, "Archive User" },
            { x => x.Color, Color.Error }
        };

        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.ExtraSmall };
        var dialog = await DialogService.ShowAsync<ShadcnConfirmDialog>("Confirm", parameters, options);
        var result = await dialog.Result;

        if (result is null || result.Canceled) return;

        try
        {
            _loading = true;
            await UserService.DeleteUserAsync(id);
            Snackbar.Add("User archived successfully", Severity.Success);
            await LoadUsers(false);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to archive user with id {UserId}.", id);
            Snackbar.Add("Unable to archive user. Please try again.", Severity.Error);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task ConfirmRestore(int id)
    {
        var parameters = new DialogParameters<ShadcnConfirmDialog>
        {
            { x => x.ContentText, "Restore User?" },
            { x => x.SubText, "This will reactivate the account with their previous permissions." },
            { x => x.ButtonText, "Restore Account" },
            { x => x.Color, Color.Success }
        };

        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.ExtraSmall };
        var dialog = await DialogService.ShowAsync<ShadcnConfirmDialog>("Confirm", parameters, options);
        var result = await dialog.Result;

        if (result is null || result.Canceled) return;

        try
        {
            _loading = true;
            await UserService.RestoreUserAsync(id);
            Snackbar.Add("User restored successfully", Severity.Success);
            await LoadUsers(true);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to restore user with id {UserId}.", id);
            Snackbar.Add("Unable to restore user. Please try again.", Severity.Error);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }
}
