@page "/admin/company-settings"
@using AccountingSystem.Shared.DTOs
@using AccountingSystem.Shared.Enums
@using AccountingSystem.Client.Services
@using AccountingSystem.Client.Shared.Dialogs
@using Microsoft.AspNetCore.Authorization
@using MudBlazor
@using System.Globalization
@attribute [Authorize(Roles = "Admin")]
@inject CompanyService CompanyService
@inject LedgerService LedgerService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ILogger<CompanySettings> Logger

<PageTitle>Company Settings - AccSys</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6 mb-10">
    <div class="d-flex justify-space-between align-center mb-6">
        <div>
            @if (isLoading)
            {
                <MudSkeleton SkeletonType="SkeletonType.Text" Width="200px" Height="32px" Class="mb-1" />
                <MudSkeleton SkeletonType="SkeletonType.Text" Width="300px" Height="16px" />
            }
            else
            {
                <h2 style="font-size: 1.5rem; font-weight: 600; letter-spacing: -0.025em; color: var(--text-main); margin: 0;">
                    Company Settings
                </h2>
                <p style="color: var(--text-muted); font-size: 0.875rem; margin: 0.25rem 0 0 0;">
                    Manage company profile and fiscal year closing.
                </p>
            }
        </div>
    </div>

    @if (isLoading)
    {
        <MudCard Elevation="0" Outlined="true" Class="shadcn-card">
            <MudCardContent>
                <div class="d-flex mb-6 gap-4 border-b pb-2">
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="120px" Height="24px" />
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="150px" Height="24px" />
                </div>

                <MudSkeleton SkeletonType="SkeletonType.Text" Width="150px" Height="24px" Class="mb-4" />

                <div class="mb-4">
                    <MudSkeleton SkeletonType="SkeletonType.Text" Width="100px" Height="16px" Class="mb-1" />
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="100%" Height="40px" Style="border-radius: 6px;" />
                </div>
                <div class="mb-4">
                    <MudSkeleton SkeletonType="SkeletonType.Text" Width="120px" Height="16px" Class="mb-1" />
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="100%" Height="80px" Style="border-radius: 6px;" />
                </div>
                <div class="d-flex gap-4 mb-6">
                    <div style="flex: 1;">
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="100%" Height="40px" Style="border-radius: 6px;" />
                    </div>
                    <div style="flex: 1;">
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="100%" Height="40px" Style="border-radius: 6px;" />
                    </div>
                    <div style="flex: 1;">
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="100%" Height="40px" Style="border-radius: 6px;" />
                    </div>
                </div>

                <div class="d-flex justify-end mt-4 pt-4 border-t">
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="140px" Height="40px" Style="border-radius: 6px;" />
                </div>
            </MudCardContent>
        </MudCard>
    }
    else
    {
        <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pt-4" Class="shadcn-tabs">

            <MudTabPanel Text="Company Profile">
                <EditForm Model="@model" OnValidSubmit="HandleSubmit">
                    <DataAnnotationsValidator />
                    <MudCard Elevation="0" Outlined="true" Class="shadcn-card">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <div style="font-size: 1.125rem; font-weight: 600; color: var(--text-main);">General Information</div>
                                <div style="font-size: 0.875rem; color: var(--text-muted);">Update your core business details and financial settings.</div>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudGrid Spacing="3">
                                <MudItem xs="12">
                                    <MudTextField Label="Company Name"
                                                  @bind-Value="model.Name"
                                                  For="@(() => model.Name)"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  Class="shadcn-input"
                                                  Required="true" />
                                </MudItem>

                                <MudItem xs="12">
                                    <MudTextField Label="Business Address"
                                                  @bind-Value="model.Address"
                                                  For="@(() => model.Address)"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  Class="shadcn-input"
                                                  Lines="3" />
                                </MudItem>

                                <MudItem xs="12" sm="4">
                                    <MudTextField Label="Tax ID / TIN"
                                                  @bind-Value="model.TaxId"
                                                  For="@(() => model.TaxId)"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  Class="shadcn-input" />
                                </MudItem>

                                <MudItem xs="12" sm="4">
                                    <MudTextField Label="Currency Code"
                                                  @bind-Value="model.Currency"
                                                  For="@(() => model.Currency)"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  Class="shadcn-input"
                                                  HelperText="e.g. PHP, USD" />
                                </MudItem>

                                <MudItem xs="12" sm="4">
                                    <MudSelect T="int"
                                               Label="Fiscal Year Start Month"
                                               @bind-Value="model.FiscalYearStartMonth"
                                               Variant="Variant.Outlined"
                                               Margin="Margin.Dense"
                                               Class="shadcn-input"
                                               AnchorOrigin="Origin.BottomCenter"
                                               HelperText="Defines boundaries">
                                        @foreach (var month in fiscalMonthOptions)
                                        {
                                            <MudSelectItem T="int" Value="@month.Key">@month.Value</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                            </MudGrid>
                        </MudCardContent>
                        <MudCardActions Class="d-flex justify-end pa-4">
                            <MudButton ButtonType="ButtonType.Submit"
                                       Variant="Variant.Filled"
                                       Class="save-btn"
                                       Size="Size.Medium"
                                       Disabled="@isSubmitting">
                                @(isSubmitting ? "Saving..." : "Save Changes")
                            </MudButton>
                        </MudCardActions>
                    </MudCard>
                </EditForm>
            </MudTabPanel>

            <MudTabPanel Text="Fiscal Year Management">
                <MudCard Elevation="0" Outlined="true" Class="shadcn-card">
                    <MudCardContent Class="pa-0">
                        <div class="pa-4 border-b">
                            <div style="font-size: 1.125rem; font-weight: 600; color: var(--text-main);">Year-End Closing</div>
                            <div style="font-size: 0.875rem; color: var(--text-muted);">Past fiscal years with activity are eligible to be securely closed.</div>
                        </div>

                        @if (fiscalYears.Count == 0)
                        {
                            <div style="text-align: center; padding: 3rem; color: var(--text-muted);">
                                <MudIcon Icon="@Icons.Material.Outlined.EventNote" Size="Size.Medium" Class="mb-2" />
                                <div style="font-size: 0.875rem;">No fiscal-year activity found yet.</div>
                            </div>
                        }
                        else
                        {
                            <MudTable Items="fiscalYears" Dense="true" Hover="true" Elevation="0" Class="shadcn-table">
                                <HeaderContent>
                                    <MudTh>Fiscal Year</MudTh>
                                    <MudTh>Period</MudTh>
                                    <MudTh Style="text-align:right;">Net Income</MudTh>
                                    <MudTh>Status</MudTh>
                                    <MudTh>Closed At (UTC)</MudTh>
                                    <MudTh Style="text-align:right;">Action</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="Fiscal Year" Style="font-weight: 500; color: var(--text-main);">FY @context.FiscalYear</MudTd>
                                    <MudTd DataLabel="Period" Style="color: var(--text-muted);">@context.PeriodStart.ToString("yyyy-MM-dd") to @context.PeriodEnd.ToString("yyyy-MM-dd")</MudTd>
                                    <MudTd DataLabel="Net Income" Style="text-align:right; font-variant-numeric: tabular-nums; font-weight: 500;">@context.NetIncome.ToString("C2", _phCulture)</MudTd>
                                    <MudTd DataLabel="Status">
                                        @if (context.IsClosed)
                                        {
                                            <span class="shadcn-badge badge-green">Closed</span>
                                        }
                                        else
                                        {
                                            <span class="shadcn-badge badge-orange">Open</span>
                                        }
                                    </MudTd>
                                    <MudTd DataLabel="Closed At (UTC)" Style="color: var(--text-muted); font-size: 0.875rem;">
                                        @(context.ClosedAtUtc.HasValue? context.ClosedAtUtc.Value.ToString("yyyy-MM-dd HH:mm") : "—")
                                    </MudTd>
                                    <MudTd DataLabel="Action" Style="text-align:right;">
                                        @if (context.CanClose && closingYear != context.FiscalYear)
                                        {
                                            <MudButton Variant="Variant.Filled"
                                                       Class="custom-button"
                                                       Size="Size.Small"
                                                       OnClick="@(() => RunYearEndCloseAsync(context.FiscalYear))">
                                                Close Year
                                            </MudButton>
                                        }
                                        else if (closingYear == context.FiscalYear)
                                        {
                                            <MudButton Variant="Variant.Filled"
                                                       Class="custom-button"
                                                       Size="Size.Small"
                                                       Disabled="true">
                                                Closing...
                                            </MudButton>
                                        }
                                        else
                                        {
                                            <MudButton Variant="Variant.Outlined"
                                                       Class="shadcn-btn-outline"
                                                       Size="Size.Small"
                                                       Disabled="true">
                                                Locked
                                            </MudButton>
                                        }
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                    </MudCardContent>
                </MudCard>
            </MudTabPanel>

            <MudTabPanel Text="Document Numbering">
                <MudCard Elevation="0" Outlined="true" Class="shadcn-card">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <div style="font-size: 1.125rem; font-weight: 600; color: var(--text-main);">Document Numbering</div>
                            <div style="font-size: 0.875rem; color: var(--text-muted);">Configure prefixes and next values for auto-generated documents.</div>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudTable Items="@documentSequences" Dense="true" Hover="true">
                            <HeaderContent>
                                <MudTh>Document Type</MudTh><MudTh>Prefix</MudTh><MudTh>Next Number</MudTh><MudTh></MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>@context.DocumentType</MudTd>
                                <MudTextField @bind-Value="context.Prefix" Margin="Margin.Dense" Variant="Variant.Outlined" />
                                <MudNumericField T="int" @bind-Value="context.NextNumber" Margin="Margin.Dense" Variant="Variant.Outlined" Min="1" />
                                <MudTd><MudButton Variant="Variant.Text" OnClick="@(() => SaveSequenceAsync(context))">Save</MudButton></MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudCardContent>
                </MudCard>
            </MudTabPanel>
        </MudTabs>
    }
</MudContainer>

@code {
    private UpdateCompanyDTO model = new();
    private List<FiscalYearSummaryDTO> fiscalYears = new();
    private List<DocumentSequenceDTO> documentSequences = new();

    private bool isLoading = true;
    private bool isSubmitting;
    private int closingYear;
    private readonly CultureInfo _phCulture = CultureInfo.GetCultureInfo("en-PH");

    private readonly Dictionary<int, string> fiscalMonthOptions = new()
    {
        { 1, "1 - January" },
        { 2, "2 - February" },
        { 3, "3 - March" },
        { 4, "4 - April" },
        { 5, "5 - May" },
        { 6, "6 - June" },
        { 7, "7 - July" },
        { 8, "8 - August" },
        { 9, "9 - September" },
        { 10, "10 - October" },
        { 11, "11 - November" },
        { 12, "12 - December" }
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadPageDataAsync();
    }

    private async Task LoadPageDataAsync()
    {
        isLoading = true;
        try
        {
            var companyTask = CompanyService.GetCurrentCompanyAsync();
            var fiscalYearsTask = LedgerService.GetFiscalYearSummariesAsync();
            var sequenceTask = CompanyService.GetDocumentSequencesAsync();
            await Task.WhenAll(companyTask, fiscalYearsTask, sequenceTask);

            var current = companyTask.Result;
            if (current != null)
            {
                model.Name = current.Name;
                model.Address = current.Address;
                model.TaxId = current.TaxId;
                model.Currency = current.Currency;
                model.FiscalYearStartMonth = current.FiscalYearStartMonth;
            }
            else
            {
                Snackbar.Add("No company profile found.", Severity.Warning);
            }

            fiscalYears = (fiscalYearsTask.Result ?? new List<FiscalYearSummaryDTO>())
                .OrderByDescending(f => f.FiscalYear)
                .ToList();
            documentSequences = sequenceTask.Result ?? new List<DocumentSequenceDTO>();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load company settings.");
            Snackbar.Add("Failed to load settings. Please try again.", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }


    private async Task SaveSequenceAsync(DocumentSequenceDTO sequence)
    {
        try
        {
            await CompanyService.UpdateDocumentSequenceAsync(new UpdateDocumentSequenceDTO
            {
                DocumentType = sequence.DocumentType,
                Prefix = sequence.Prefix,
                NextNumber = sequence.NextNumber
            });
            Snackbar.Add($"{sequence.DocumentType} numbering updated.", Severity.Success);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save document sequence for {DocumentType}.", sequence.DocumentType);
            Snackbar.Add("Failed to save sequence. Please try again.", Severity.Error);
        }
    }

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        try
        {
            await CompanyService.UpdateCompanyAsync(model);
            Snackbar.Add("Company profile updated successfully.", Severity.Success);
            await ReloadFiscalYearsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to update company profile.");
            Snackbar.Add("Update failed. Please try again.", Severity.Error);
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task ReloadFiscalYearsAsync()
    {
        try
        {
            fiscalYears = (await LedgerService.GetFiscalYearSummariesAsync() ?? new List<FiscalYearSummaryDTO>())
                .OrderByDescending(f => f.FiscalYear)
                .ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load fiscal years.");
            Snackbar.Add("Failed to load fiscal years. Please try again.", Severity.Error);
        }
    }

    private async Task<bool> ShowConfirmDialog(string content, string subText, string buttonText, Color color)
    {
        var parameters = new DialogParameters
        {
            [nameof(ShadcnConfirmDialog.ContentText)] = content,
            [nameof(ShadcnConfirmDialog.SubText)] = subText,
            [nameof(ShadcnConfirmDialog.ButtonText)] = buttonText,
            [nameof(ShadcnConfirmDialog.Color)] = color
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ShadcnConfirmDialog>("Confirm", parameters, options);
        var result = await dialog.Result;
        return result is not null && !result.Canceled;
    }

    private async Task RunYearEndCloseAsync(int fiscalYear)
    {
        var confirm = await ShowConfirmDialog(
            $"Run year-end close for FY {fiscalYear}?",
            "This action marks the fiscal year as closed for new postings.",
            "Run Close",
            Color.Warning);

        if (!confirm)
            return;

        closingYear = fiscalYear;
        try
        {
            var result = await LedgerService.RunYearEndCloseAsync(fiscalYear);
            Snackbar.Add(
                $"FY {fiscalYear} closed successfully. Closing JE #{result?.ClosingJournalEntryId} posted.",
                Severity.Success);
            await ReloadFiscalYearsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Year-end close failed for fiscal year {FiscalYear}.", fiscalYear);
            Snackbar.Add("Year-end close failed. Please try again.", Severity.Error);
        }
        finally
        {
            closingYear = 0;
        }
    }
}
