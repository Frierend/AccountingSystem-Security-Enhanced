@page "/reports/financials"
@using AccountingSystem.Shared.DTOs
@using AccountingSystem.Client.Services
@using MudBlazor
@using System.Globalization
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject ReportService ReportService
@inject LedgerService LedgerService
@inject CompanyService CompanyService
@inject ISnackbar Snackbar
@inject ILogger<FinancialReports> Logger

<PageTitle>Financial Reports - AccSys</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6 mb-10" id="printable-area">

    <div class="d-flex justify-space-between align-center flex-wrap mb-6 no-print" style="gap: 12px;">
        <div>
            <h2 style="font-size: 1.5rem; font-weight: 600; letter-spacing: -0.025em; color: var(--text-main); margin: 0;">
                Financial Statements
            </h2>
            <p style="color: var(--text-muted); font-size: 0.875rem; margin: 0.25rem 0 0 0;">
                Fiscal-year financial position and performance.
            </p>
        </div>
        <div class="d-flex align-center flex-wrap" style="gap: 12px;">
            <MudSelect T="int"
                       Value="selectedFiscalYear"
                       ValueChanged="OnFiscalYearChanged"
                       Label="Fiscal Year"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Class="shadcn-input"
                       AnchorOrigin="Origin.BottomCenter"
                       Disabled="@(isLoading || fiscalYears.Count == 0)"
                       Style="min-width: 170px; margin-top: 0;">
                @foreach (var year in fiscalYears)
                {
                    <MudSelectItem T="int" Value="@year.FiscalYear">FY @year.FiscalYear</MudSelectItem>
                }
            </MudSelect>

            <MudButton Variant="Variant.Filled"
                       Class="custom-button"
                       StartIcon="@Icons.Material.Outlined.PictureAsPdf"
                       Size="Size.Small"
                       OnClick="PrintReport"
                       Disabled="@(isLoading || selectedFiscalYear == 0)">
                Download PDF
            </MudButton>
        </div>
    </div>

    @if (isLoading)
    {
        <MudCard Elevation="0" Outlined="true" Class="shadcn-card pa-10" Style="text-align: center;">
            <MudProgressCircular Color="Color.Default" Indeterminate="true" Size="Size.Medium" Style="color: var(--text-muted);" />
            <div style="color: var(--text-muted); font-size: 0.875rem; margin-top: 1rem;">Loading financial data...</div>
        </MudCard>
    }
    else if (currentCompany == null)
    {
        <MudAlert Severity="Severity.Warning" Elevation="0" Class="shadcn-card">Company profile is missing. Please configure it in settings.</MudAlert>
    }
    else if (selectedFiscalYear == 0 || incomeTrialBalance == null || balanceTrialBalance == null)
    {
        <MudAlert Severity="Severity.Info" Elevation="0" Class="shadcn-card">No fiscal-year data available yet.</MudAlert>
    }
    else
    {
        <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pt-4" Class="shadcn-tabs no-print-tabs" Centered="true">

            <MudTabPanel Text="Trial Balance">
                <MudCard Elevation="0" Outlined="true" Class="shadcn-card pa-8 report-paper">
                    <div class="report-header mb-8" style="text-align: center; display: flex; flex-direction: column; align-items: center;">
                        <div style="font-size: 1.5rem; font-weight: 700; color: var(--text-main); letter-spacing: -0.025em;">@currentCompany.Name</div>
                        @if (!string.IsNullOrEmpty(currentCompany.Address))
                        {
                            <div style="font-size: 0.875rem; color: var(--text-muted);">@currentCompany.Address</div>
                        }
                        @if (!string.IsNullOrEmpty(currentCompany.TaxId))
                        {
                            <div style="font-size: 0.75rem; color: var(--text-muted);">TIN: @currentCompany.TaxId</div>
                        }

                        <div style="font-size: 1.125rem; font-weight: 600; color: var(--text-main); margin-top: 1.5rem;">Trial Balance</div>
                        <div style="font-size: 0.875rem; color: var(--text-muted);">As of @selectedPeriodEnd.ToString("MMMM dd, yyyy") (FY @selectedFiscalYear)</div>
                        <hr style="border: 0; border-top: 1px solid var(--border-color); width: 100px; margin: 1.5rem auto;" />
                    </div>

                    <div class="table-responsive-wrapper">
                        <table class="w-100 shadcn-report-table">
                            <thead>
                                <tr>
                                    <th style="text-align: left;">ACCOUNT CODE</th>
                                    <th style="text-align: left;">ACCOUNT NAME</th>
                                    <th style="text-align: right;">DEBIT</th>
                                    <th style="text-align: right;">CREDIT</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var line in balanceTrialBalance.Accounts.OrderBy(a => a.AccountCode))
                                {
                                    var net = line.Debit - line.Credit;
                                    var displayDebit = net > 0 ? net : 0;
                                    var displayCredit = net < 0 ? Math.Abs(net) : 0;

                                    <tr>
                                        <td style="color: var(--text-muted);">@line.AccountCode</td>
                                        <td>@line.AccountName</td>
                                        <td class="tabular-nums text-right">@displayDebit.ToString("C2", _phCulture)</td>
                                        <td class="tabular-nums text-right">@displayCredit.ToString("C2", _phCulture)</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                @{
                                    var totalNetDebit = balanceTrialBalance.Accounts.Sum(a => (a.Debit - a.Credit) > 0 ? (a.Debit - a.Credit) : 0);
                                    var totalNetCredit = balanceTrialBalance.Accounts.Sum(a => (a.Debit - a.Credit) < 0 ? Math.Abs(a.Debit - a.Credit) : 0);
                                }
                                <tr class="totals-row">
                                    <td colspan="2" style="text-align:right; font-weight: 600;">TOTALS:</td>
                                    <td class="tabular-nums text-right double-underline" style="font-weight: 700;">@totalNetDebit.ToString("C2", _phCulture)</td>
                                    <td class="tabular-nums text-right double-underline" style="font-weight: 700;">@totalNetCredit.ToString("C2", _phCulture)</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </MudCard>
            </MudTabPanel>

            <MudTabPanel Text="Income Statement">
                <MudCard Elevation="0" Outlined="true" Class="shadcn-card pa-8 report-paper">
                    <div class="report-header mb-8" style="text-align: center; display: flex; flex-direction: column; align-items: center;">
                        <div style="font-size: 1.5rem; font-weight: 700; color: var(--text-main); letter-spacing: -0.025em;">@currentCompany.Name</div>
                        @if (!string.IsNullOrEmpty(currentCompany.Address))
                        {
                            <div style="font-size: 0.875rem; color: var(--text-muted);">@currentCompany.Address</div>
                        }
                        @if (!string.IsNullOrEmpty(currentCompany.TaxId))
                        {
                            <div style="font-size: 0.75rem; color: var(--text-muted);">TIN: @currentCompany.TaxId</div>
                        }

                        <div style="font-size: 1.125rem; font-weight: 600; color: var(--text-main); margin-top: 1.5rem;">Income Statement</div>
                        <div style="font-size: 0.875rem; color: var(--text-muted);">For @selectedPeriodStart.ToString("MMMM dd, yyyy") to @selectedPeriodEnd.ToString("MMMM dd, yyyy") (FY @selectedFiscalYear)</div>
                        <hr style="border: 0; border-top: 1px solid var(--border-color); width: 100px; margin: 1.5rem auto;" />
                    </div>

                    <div class="table-responsive-wrapper">
                        <table class="w-100 shadcn-report-table">
                            <tbody>
                                <tr class="category-header"><td colspan="2">REVENUE</td></tr>
                                @foreach (var line in GetAccountsByType(incomeTrialBalance, "Revenue"))
                                {
                                    <tr>
                                        <td class="pl-8">@line.AccountName</td>
                                        <td class="tabular-nums text-right">@((line.Credit - line.Debit).ToString("C2", _phCulture))</td>
                                    </tr>
                                }
                                <tr class="subtotal-row">
                                    <td class="text-right font-weight-600">Total Revenue</td>
                                    <td class="tabular-nums text-right font-weight-600">@TotalRevenue.ToString("C2", _phCulture)</td>
                                </tr>

                                <tr><td colspan="2" class="py-4 border-0"></td></tr>

                                <tr class="category-header"><td colspan="2">OPERATING EXPENSES</td></tr>
                                @foreach (var line in GetAccountsByType(incomeTrialBalance, "Expense"))
                                {
                                    <tr>
                                        <td class="pl-8">@line.AccountName</td>
                                        <td class="tabular-nums text-right">@((line.Debit - line.Credit).ToString("C2", _phCulture))</td>
                                    </tr>
                                }
                                <tr class="subtotal-row">
                                    <td class="text-right font-weight-600">Total Expenses</td>
                                    <td class="tabular-nums text-right font-weight-600">(@TotalExpense.ToString("C2", _phCulture))</td>
                                </tr>

                                <tr><td colspan="2" class="py-6 border-0"></td></tr>

                                <tr class="grand-total-row">
                                    <td style="font-size: 1.125rem;">NET INCOME</td>
                                    <td class="tabular-nums text-right double-underline" style="font-size: 1.125rem;">@NetIncome.ToString("C2", _phCulture)</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </MudCard>
            </MudTabPanel>

            <MudTabPanel Text="Balance Sheet">
                <MudCard Elevation="0" Outlined="true" Class="shadcn-card pa-8 report-paper">
                    <div class="report-header mb-8" style="text-align: center; display: flex; flex-direction: column; align-items: center;">
                        <div style="font-size: 1.5rem; font-weight: 700; color: var(--text-main); letter-spacing: -0.025em;">@currentCompany.Name</div>
                        @if (!string.IsNullOrEmpty(currentCompany.Address))
                        {
                            <div style="font-size: 0.875rem; color: var(--text-muted);">@currentCompany.Address</div>
                        }
                        @if (!string.IsNullOrEmpty(currentCompany.TaxId))
                        {
                            <div style="font-size: 0.75rem; color: var(--text-muted);">TIN: @currentCompany.TaxId</div>
                        }

                        <div style="font-size: 1.125rem; font-weight: 600; color: var(--text-main); margin-top: 1.5rem;">Balance Sheet</div>
                        <div style="font-size: 0.875rem; color: var(--text-muted);">As of @selectedPeriodEnd.ToString("MMMM dd, yyyy") (FY @selectedFiscalYear)</div>
                        <hr style="border: 0; border-top: 1px solid var(--border-color); width: 100px; margin: 1.5rem auto;" />
                    </div>

                    <div class="table-responsive-wrapper">
                        <table class="w-100 shadcn-report-table">
                            <tbody>
                                <tr class="category-header"><td colspan="2">ASSETS</td></tr>
                                @foreach (var line in GetAccountsByType(balanceTrialBalance, "Asset"))
                                {
                                    <tr>
                                        <td class="pl-8">@line.AccountName</td>
                                        <td class="tabular-nums text-right">@((line.Debit - line.Credit).ToString("C2", _phCulture))</td>
                                    </tr>
                                }
                                <tr class="subtotal-row">
                                    <td class="text-right font-weight-600">TOTAL ASSETS</td>
                                    <td class="tabular-nums text-right font-weight-700 double-underline">@TotalAssets.ToString("C2", _phCulture)</td>
                                </tr>

                                <tr><td colspan="2" class="py-6 border-0"></td></tr>

                                <tr class="category-header"><td colspan="2">LIABILITIES</td></tr>
                                @foreach (var line in GetAccountsByType(balanceTrialBalance, "Liability"))
                                {
                                    <tr>
                                        <td class="pl-8">@line.AccountName</td>
                                        <td class="tabular-nums text-right">@((line.Credit - line.Debit).ToString("C2", _phCulture))</td>
                                    </tr>
                                }
                                <tr class="subtotal-row">
                                    <td class="text-right font-weight-600">Total Liabilities</td>
                                    <td class="tabular-nums text-right font-weight-600">@TotalLiabilities.ToString("C2", _phCulture)</td>
                                </tr>

                                <tr><td colspan="2" class="py-4 border-0"></td></tr>

                                <tr class="category-header"><td colspan="2">EQUITY</td></tr>
                                @foreach (var line in GetAccountsByType(balanceTrialBalance, "Equity"))
                                {
                                    <tr>
                                        <td class="pl-8">@line.AccountName</td>
                                        <td class="tabular-nums text-right">@((line.Credit - line.Debit).ToString("C2", _phCulture))</td>
                                    </tr>
                                }
                                <tr>
                                    <td class="pl-8" style="color: var(--text-muted); font-style: italic;">Net Income (Current Fiscal Year)</td>
                                    <td class="tabular-nums text-right">@NetIncome.ToString("C2", _phCulture)</td>
                                </tr>
                                <tr class="subtotal-row">
                                    <td class="text-right font-weight-600">Total Equity</td>
                                    <td class="tabular-nums text-right font-weight-600">@TotalEquity.ToString("C2", _phCulture)</td>
                                </tr>

                                <tr><td colspan="2" class="py-6 border-0"></td></tr>

                                <tr class="grand-total-row">
                                    <td style="font-size: 1.125rem;">TOTAL LIABILITIES & EQUITY</td>
                                    <td class="tabular-nums text-right double-underline" style="font-size: 1.125rem;">@((TotalLiabilities + TotalEquity).ToString("C2", _phCulture))</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </MudCard>
            </MudTabPanel>
        </MudTabs>
    }
</MudContainer>

<style>
    /* Responsive Table Wrapper */
    .table-responsive-wrapper {
        width: 100%;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch; /* Smooth scrolling on iOS */
    }

    /* Shadcn Report Table Styles */
    .shadcn-report-table {
        border-collapse: collapse;
        width: 100%;
        color: var(--text-main);
        font-size: 0.875rem;
        min-width: 600px; /* Forces scrollbar on small screens instead of squishing */
    }

        .shadcn-report-table th {
            font-weight: 600;
            color: var(--text-muted);
            border-bottom: 1px solid var(--border-color);
            padding: 0.75rem 1rem;
            font-size: 0.75rem;
            letter-spacing: 0.05em;
        }

        .shadcn-report-table td {
            padding: 0.5rem 1rem;
            border-bottom: 1px solid var(--border-color);
        }

        .shadcn-report-table tr:last-child td {
            border-bottom: none;
        }

    /* Standard Utilities */
    .tabular-nums {
        font-variant-numeric: tabular-nums;
    }

    .text-right {
        text-align: right;
    }

    .font-weight-600 {
        font-weight: 600;
    }

    .font-weight-700 {
        font-weight: 700;
    }

    .pl-8 {
        padding-left: 2rem !important;
    }

    .border-0 {
        border: none !important;
    }

    /* Report specific rows */
    .category-header td {
        background-color: var(--bg-muted);
        font-weight: 600;
        font-size: 0.75rem;
        letter-spacing: 0.05em;
        color: var(--text-muted);
        padding: 0.5rem 1rem;
    }

    .subtotal-row td {
        border-top: 1px solid var(--border-color);
        padding-top: 0.75rem;
        padding-bottom: 0.75rem;
    }

    .totals-row td {
        border-top: 2px solid var(--text-main);
        padding-top: 1rem;
        padding-bottom: 1rem;
    }

    .grand-total-row td {
        border-top: 2px solid var(--text-main);
        font-weight: 700;
        padding-top: 1.25rem;
        padding-bottom: 1.25rem;
    }

    .double-underline {
        border-bottom: 3px double var(--text-main) !important;
    }

    /* Print Styles */
    @@media print {
        body {
            background-color: white !important;
            color: black !important;
        }

        .no-print, .no-print-tabs .mud-tabs-toolbar {
            display: none !important;
        }

        .mud-appbar, .mud-drawer, .mud-drawer-overlay {
            display: none !important;
        }

        .mud-main-content {
            padding: 0 !important;
            margin: 0 !important;
            max-width: 100% !important;
        }

        .mud-container {
            padding: 0 !important;
            max-width: 100% !important;
            margin: 0 !important;
        }

        .report-paper {
            box-shadow: none !important;
            border: none !important;
            padding: 0 !important;
        }

        .table-responsive-wrapper {
            overflow-x: visible !important; /* Remove scroll behavior on print */
        }

        .shadcn-report-table {
            min-width: 100% !important; /* Ensure table fits page on print */
        }

        .category-header td {
            background-color: #f3f4f6 !important; /* Force light gray on print */
            -webkit-print-color-adjust: exact;
        }
    }
</style>

@code {
    private TrialBalanceDTO? incomeTrialBalance;
    private TrialBalanceDTO? balanceTrialBalance;
    private CompanyDTO? currentCompany;
    private Dictionary<string, string> accountTypes = new();
    private List<FiscalYearSummaryDTO> fiscalYears = new();

    private int selectedFiscalYear;
    private DateTime selectedPeriodStart;
    private DateTime selectedPeriodEnd;
    private bool isLoading;

    private readonly CultureInfo _phCulture = CultureInfo.GetCultureInfo("en-PH");

    private decimal TotalRevenue => GetAccountsByType(incomeTrialBalance, "Revenue").Sum(a => a.Credit - a.Debit);
    private decimal TotalExpense => GetAccountsByType(incomeTrialBalance, "Expense").Sum(a => a.Debit - a.Credit);
    private decimal NetIncome => TotalRevenue - TotalExpense;
    private decimal TotalAssets => GetAccountsByType(balanceTrialBalance, "Asset").Sum(a => a.Debit - a.Credit);
    private decimal TotalLiabilities => GetAccountsByType(balanceTrialBalance, "Liability").Sum(a => a.Credit - a.Debit);
    private decimal TotalEquity => GetAccountsByType(balanceTrialBalance, "Equity").Sum(a => a.Credit - a.Debit) + NetIncome;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            var fiscalYearsTask = LedgerService.GetFiscalYearSummariesAsync();
            var accountsTask = LedgerService.GetAccountsAsync();
            var companyTask = CompanyService.GetCurrentCompanyAsync();

            await Task.WhenAll(fiscalYearsTask, accountsTask, companyTask);

            currentCompany = companyTask.Result;

            var accounts = accountsTask.Result;
            accountTypes = accounts != null
                ? accounts.ToDictionary(a => a.Code, a => a.Type)
                : new Dictionary<string, string>();

            fiscalYears = (fiscalYearsTask.Result ?? new List<FiscalYearSummaryDTO>())
                .OrderByDescending(f => f.FiscalYear)
                .ToList();

            if (fiscalYears.Count > 0)
            {
                selectedFiscalYear = fiscalYears[0].FiscalYear;
                await LoadYearData(selectedFiscalYear);
            }
            else
            {
                selectedFiscalYear = 0;
                incomeTrialBalance = null;
                balanceTrialBalance = null;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load financial report data.");
            Snackbar.Add("Failed to load reports. Please try again.", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OnFiscalYearChanged(int fiscalYear)
    {
        selectedFiscalYear = fiscalYear;
        await LoadYearData(fiscalYear);
    }

    private async Task LoadYearData(int fiscalYear)
    {
        var selected = fiscalYears.FirstOrDefault(f => f.FiscalYear == fiscalYear);
        if (selected == null)
            return;

        selectedPeriodStart = selected.PeriodStart.Date;
        selectedPeriodEnd = selected.PeriodEnd.Date;

        var incomeTask = ReportService.GetTrialBalance(selectedPeriodStart, selectedPeriodEnd, excludeClosingEntries: true);
        var balanceTask = ReportService.GetTrialBalance(null, selectedPeriodEnd);

        await Task.WhenAll(incomeTask, balanceTask);
        incomeTrialBalance = incomeTask.Result;
        balanceTrialBalance = balanceTask.Result;
    }

    private IEnumerable<AccountBalanceDTO> GetAccountsByType(TrialBalanceDTO? source, string type)
    {
        if (source == null)
            return Enumerable.Empty<AccountBalanceDTO>();

        return source.Accounts
            .Where(a => accountTypes.ContainsKey(a.AccountCode) && accountTypes[a.AccountCode] == type)
            .OrderBy(a => a.AccountCode);
    }

    private async Task PrintReport()
    {
        if (selectedFiscalYear == 0)
        {
            Snackbar.Add("Select a fiscal year first.", Severity.Warning);
            return;
        }

        try
        {
            Snackbar.Add("Generating Financial Report PDF...", Severity.Info);
            await ReportService.DownloadFinancialsPdf(selectedFiscalYear);
            Snackbar.Add("Download started.", Severity.Success);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to generate financial reports PDF.");
            Snackbar.Add("Download failed. Please try again.", Severity.Error);
        }
    }
}
