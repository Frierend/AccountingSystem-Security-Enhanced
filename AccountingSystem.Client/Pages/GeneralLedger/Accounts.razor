@page "/gl/accounts"
@using AccountingSystem.Shared.DTOs
@using AccountingSystem.Client.Services
@using AccountingSystem.Client.Shared.Dialogs
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor
@attribute [Authorize(Roles = "Admin,Accounting,Management")]
@inject LedgerService LedgerService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject ILogger<Accounts> Logger

<style>
    /* Shadcn-style custom colored badges */
    .shadcn-badge {
        display: inline-flex;
        align-items: center;
        padding: 2px 8px;
        border-radius: 4px; /* Crisp corners */
        font-size: 0.75rem;
        font-weight: 600;
        white-space: nowrap;
        letter-spacing: 0.025em;
    }

    /* The Colors: Light pastel background with deep colored text */
    .badge-slate { background-color: #f1f5f9; color: #475569; }
    .badge-purple { background-color: #f3e8ff; color: #7e22ce; }
    .badge-blue { background-color: #e0f2fe; color: #0369a1; }
    .badge-orange { background-color: #ffedd5; color: #c2410c; }
    .badge-green { background-color: #dcfce7; color: #15803d; }
    .badge-red { background-color: #fee2e2; color: #b91c1c; }
    .badge-indigo { background-color: #e0e7ff; color: #4338ca; }

    /* Responsive Filters & Tweaks */
    .table-toolbar-wrapper {
        display: flex;
        flex-direction: row;
        justify-content: space-between;
        align-items: center;
        width: 100%;
        gap: 1rem;
    }

    .table-toolbar-actions {
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 0.75rem;
    }

    .filter-search {
        width: 100%;
        max-width: 300px;
    }

    /* Fix for MudTable ToolBar overlapping on mobile */
    .shadcn-table .mud-table-toolbar {
        height: auto !important;
        padding-top: 1rem !important;
        padding-bottom: 1rem !important;
    }

    /* Responsive Skeletons */
    @@media (max-width: 599px) {
        .desktop-skeleton { display: none !important; }
        
        .table-toolbar-wrapper {
            flex-direction: column;
            align-items: flex-start;
        }

        .table-toolbar-actions {
            flex-direction: column;
            width: 100%;
            align-items: stretch; /* Make inputs fill the container */
        }

        .filter-search {
            max-width: 100%;
        }
    }
    
    @@media (min-width: 600px) {
        .mobile-skeleton { display: none !important; }
    }
</style>

<PageTitle>Chart of Accounts - AccSys</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6 mb-10">
    <div class="d-flex flex-column flex-sm-row justify-space-between align-start align-sm-center mb-6 gap-3">
        <div>
            @if (_initialLoading)
            {
                <MudSkeleton SkeletonType="SkeletonType.Text" Width="200px" Height="32px" Class="mb-1" />
                <MudSkeleton SkeletonType="SkeletonType.Text" Width="100%" Style="max-width: 350px;" Height="16px" />
            }
            else
            {
                <h2 style="font-size: 1.5rem; font-weight: 600; letter-spacing: -0.025em; color: var(--text-main); margin: 0;">
                    Chart of Accounts
                </h2>
                <p style="color: var(--text-muted); font-size: 0.875rem; margin: 0.25rem 0 0 0;">
                    Set up account classifications to track your business financial activities.
                </p>
            }
        </div>
        @if (_initialLoading)
        {
            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="150px" Height="36px" Style="border-radius: 6px;" />
        }
        else
        {
            <AuthorizeView Roles="Admin,Accounting" Context="authContext">
                <MudButton Variant="Variant.Filled"
                           Class="custom-button"
                           StartIcon="@Icons.Material.Outlined.Add"
                           Size="Size.Small"
                           OnClick="OpenAddDialog">
                    Add Account
                </MudButton>
            </AuthorizeView>
        }
    </div>

    @if (_initialLoading)
    {
        <MudCard Elevation="0" Outlined="true" Class="shadcn-card">
            <div class="d-flex pa-4 border-b">
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="140px" Height="24px" Class="mr-4" />
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="160px" Height="24px" Class="desktop-skeleton" />
            </div>

            <MudCardContent Class="pa-0">
                <div class="d-flex flex-column flex-sm-row justify-space-between align-start align-sm-center pa-4 border-b gap-3">
                    <MudSkeleton SkeletonType="SkeletonType.Text" Width="120px" Height="24px" />
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="100%" Style="max-width: 250px;" Height="36px" Class="rounded-md" />
                </div>

                <div class="d-flex justify-space-between mb-2 pa-4 border-b desktop-skeleton">
                    <MudSkeleton SkeletonType="SkeletonType.Text" Width="80px" Height="20px" />
                    <MudSkeleton SkeletonType="SkeletonType.Text" Width="150px" Height="20px" />
                    <MudSkeleton SkeletonType="SkeletonType.Text" Width="90px" Height="20px" />
                    <MudSkeleton SkeletonType="SkeletonType.Text" Width="80px" Height="20px" />
                </div>

                @for (int i = 0; i < 6; i++)
                {
                    <div class="d-flex justify-space-between align-center py-3 px-4 desktop-skeleton" style="border-bottom: 1px solid var(--border-color);">
                        <div style="flex: 1;"><MudSkeleton SkeletonType="SkeletonType.Text" Width="60px" Height="16px" /></div>
                        <div style="flex: 2;"><MudSkeleton SkeletonType="SkeletonType.Text" Width="180px" Height="16px" /></div>
                        <div style="flex: 1;"><MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="70px" Height="24px" Style="border-radius: 4px;" /></div>
                        <div style="flex: 1; text-align: right;">
                            <div class="d-flex justify-end gap-2">
                                <MudSkeleton SkeletonType="SkeletonType.Circle" Width="28px" Height="28px" />
                                <MudSkeleton SkeletonType="SkeletonType.Circle" Width="28px" Height="28px" />
                            </div>
                        </div>
                    </div>

                    <div class="d-flex flex-column py-3 px-4 mobile-skeleton gap-2" style="border-bottom: 1px solid var(--border-color);">
                        <div class="d-flex justify-space-between align-center">
                            <MudSkeleton SkeletonType="SkeletonType.Text" Width="60px" Height="16px" />
                            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="70px" Height="24px" Style="border-radius: 4px;" />
                        </div>
                        <MudSkeleton SkeletonType="SkeletonType.Text" Width="80%" Height="16px" />
                        <div class="d-flex justify-end gap-2 mt-1">
                            <MudSkeleton SkeletonType="SkeletonType.Circle" Width="28px" Height="28px" />
                            <MudSkeleton SkeletonType="SkeletonType.Circle" Width="28px" Height="28px" />
                        </div>
                    </div>
                }

                <div class="d-flex justify-end pa-4">
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="100%" Style="max-width: 250px;" Height="32px" Class="rounded-md" />
                </div>
            </MudCardContent>
        </MudCard>
    }
    else
    {
        <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pt-4" Class="shadcn-tabs">

            <MudTabPanel Text="Active Accounts" OnClick="@(() => LoadList(false))">
                <MudCard Elevation="0" Outlined="true" Class="shadcn-card">
                    <MudTable Items="@accounts" Dense="true" Hover="true" Elevation="0" Filter="new Func<AccountDTO, bool>(FilterFunc)" Loading="@_loading" Class="shadcn-table" Breakpoint="Breakpoint.Sm">
                        <ToolBarContent>
                            <div class="table-toolbar-wrapper">
                                <div style="font-size: 1.125rem; font-weight: 600; color: var(--text-main);">Active List</div>
                                <div class="table-toolbar-actions">
                                    <MudTextField @bind-Value="searchString"
                                                  Placeholder="Search accounts..."
                                                  Adornment="Adornment.Start"
                                                  AdornmentIcon="@Icons.Material.Outlined.Search"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  Class="shadcn-input filter-search m-0"></MudTextField>
                                </div>
                            </div>
                        </ToolBarContent>
                        <HeaderContent>
                            <MudTh>Code</MudTh>
                            <MudTh>Name</MudTh>
                            <MudTh>Type</MudTh>
                            <AuthorizeView Roles="Admin,Accounting" Context="authContext">
                                <MudTh Style="text-align:right">Actions</MudTh>
                            </AuthorizeView>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Code" Style="font-weight: 500; color: var(--text-main);">@context.Code</MudTd>
                            <MudTd DataLabel="Name" Style="color: var(--text-muted);">@context.Name</MudTd>
                            <MudTd DataLabel="Type">
                                <span class="shadcn-badge @GetAccountTypeBadge(context.Type)">@context.Type</span>
                            </MudTd>
                            <AuthorizeView Roles="Admin,Accounting" Context="authContext">
                                <MudTd DataLabel="Actions" Style="text-align:right">
                                    <MudIconButton Icon="@Icons.Material.Outlined.Edit"
                                                   Size="Size.Small"
                                                   Class="shadcn-icon-btn mr-1"
                                                   OnClick="() => OpenEditDialog(context)" />
                                    <MudIconButton Icon="@Icons.Material.Outlined.Archive"
                                                   Size="Size.Small"
                                                   Class="shadcn-icon-btn text-destructive"
                                                   OnClick="() => ConfirmDelete(context.Id)" />
                                </MudTd>
                            </AuthorizeView>
                        </RowTemplate>
                        <PagerContent><MudTablePager /></PagerContent>
                    </MudTable>
                </MudCard>
            </MudTabPanel>

            <AuthorizeView Roles="Admin,Accounting" Context="authContext">
                <MudTabPanel Text="Archived Accounts" OnClick="@(() => LoadList(true))">
                    <MudCard Elevation="0" Outlined="true" Class="shadcn-card">
                        <MudTable Items="@accounts" Dense="true" Hover="true" Elevation="0" Filter="new Func<AccountDTO, bool>(FilterFunc)" Loading="@_loading" Class="shadcn-table" Breakpoint="Breakpoint.Sm">
                            <ToolBarContent>
                                <div class="table-toolbar-wrapper">
                                    <div style="font-size: 1.125rem; font-weight: 600; color: var(--text-main);">Archived List</div>
                                    <div class="table-toolbar-actions">
                                        <MudTextField @bind-Value="searchString"
                                                      Placeholder="Search archived..."
                                                      Adornment="Adornment.Start"
                                                      AdornmentIcon="@Icons.Material.Outlined.Search"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Class="shadcn-input filter-search m-0"></MudTextField>
                                    </div>
                                </div>
                            </ToolBarContent>
                            <HeaderContent>
                                <MudTh>Code</MudTh>
                                <MudTh>Name</MudTh>
                                <MudTh>Type</MudTh>
                                <MudTh Style="text-align:right">Actions</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Code" Style="color: var(--text-muted);">@context.Code</MudTd>
                                <MudTd DataLabel="Name" Style="color: var(--text-muted); text-decoration: line-through;">@context.Name</MudTd>
                                <MudTd DataLabel="Type">
                                    <span class="shadcn-badge badge-slate">@context.Type</span>
                                </MudTd>
                                <MudTd DataLabel="Actions" Style="text-align:right">
                                    <MudTooltip Text="Restore Account">
                                        <MudIconButton Icon="@Icons.Material.Outlined.RestoreFromTrash"
                                                       Size="Size.Small"
                                                       Class="shadcn-icon-btn text-success"
                                                       OnClick="() => ConfirmRestore(context.Id)" />
                                    </MudTooltip>
                                </MudTd>
                            </RowTemplate>
                            <PagerContent><MudTablePager /></PagerContent>
                        </MudTable>
                    </MudCard>
                </MudTabPanel>
            </AuthorizeView>
        </MudTabs>
    }
</MudContainer>

@code {
    private List<AccountDTO> accounts = new List<AccountDTO>();
    private string searchString = "";
    private bool _loading = true;
    private bool _initialLoading = true;
    private bool _showArchived = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadList(false);
        _initialLoading = false;
        StateHasChanged();
    }

    private async Task LoadList(bool archived)
    {
        _showArchived = archived;
        _loading = true;
        try
        {
            var all = await LedgerService.GetAccountsAsync(archived);
            if (all != null)
            {
                if (archived)
                    accounts = all.Where(a => a.IsDeleted).ToList();
                else
                    accounts = all.ToList();
            }
            else
            {
                accounts = new List<AccountDTO>();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load chart of accounts.");
            Snackbar.Add("Failed to load accounts. Please try again.", Severity.Error);
            accounts = new List<AccountDTO>();
        }
        finally { _loading = false; }
    }

    private bool FilterFunc(AccountDTO element) =>
        string.IsNullOrWhiteSpace(searchString) ||
        element.Code.Contains(searchString, StringComparison.OrdinalIgnoreCase) ||
        element.Name.Contains(searchString, StringComparison.OrdinalIgnoreCase);

    private async Task OpenAddDialog()
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<AccountDialog>("Add Account", options);
        var result = await dialog.Result;
        if (result != null && !result.Canceled) await LoadList(false);
    }

    private async Task OpenEditDialog(AccountDTO account)
    {
        var parameters = new DialogParameters { ["Account"] = account };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<AccountDialog>("Edit Account", parameters, options);
        var result = await dialog.Result;
        if (result != null && !result.Canceled) await LoadList(false);
    }

    private async Task ConfirmDelete(int id)
    {
        bool result = await ShowConfirmDialog(
            "Archive this account?",
            "It will be hidden from selection lists.",
            "Archive",
            Color.Error);
        if (result == true)
        {
            try
            {
                await LedgerService.DeleteAccountAsync(id);
                Snackbar.Add("Account archived.", Severity.Success);
                await LoadList(false); // Refresh Active list
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Failed to archive account with id {AccountId}.", id);
                Snackbar.Add("Unable to archive account. Please try again.", Severity.Error);
            }
        }
    }

    private async Task ConfirmRestore(int id)
    {
        bool result = await ShowConfirmDialog(
            "Restore this account?",
            "It will become available again in account selection lists.",
            "Restore",
            Color.Success);
        if (result == true)
        {
            try
            {
                await LedgerService.RestoreAccountAsync(id);
                Snackbar.Add("Account restored.", Severity.Success);
                await LoadList(true); // Refresh Archived list
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Failed to restore account with id {AccountId}.", id);
                Snackbar.Add("Unable to restore account. Please try again.", Severity.Error);
            }
        }
    }

    private async Task<bool> ShowConfirmDialog(string content, string subText, string buttonText, Color color)
    {
        var parameters = new DialogParameters
        {
            [nameof(ShadcnConfirmDialog.ContentText)] = content,
            [nameof(ShadcnConfirmDialog.SubText)] = subText,
            [nameof(ShadcnConfirmDialog.ButtonText)] = buttonText,
            [nameof(ShadcnConfirmDialog.Color)] = color
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ShadcnConfirmDialog>("Confirm", parameters, options);
        var result = await dialog.Result;
        return result is not null && !result.Canceled;
    }

    // Helper for Shadcn badge colors based on account type
    private string GetAccountTypeBadge(string type)
    {
        return type switch
        {
            "Asset" => "badge-blue",
            "Liability" => "badge-red",
            "Equity" => "badge-purple",
            "Revenue" => "badge-green",
            "Expense" => "badge-orange",
            _ => "badge-slate"
        };
    }
}
