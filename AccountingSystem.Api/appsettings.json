{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "__SET_VIA_ENV__"
  },
  "JwtSettings": {
    "Secret": "__SET_VIA_ENV__",
    "Issuer": "AccountingAPI",
    "Audience": "AccountingClient",
    "ExpiryMinutes": 60,
    "ClockSkewSeconds": 60
  },
  "IdentityTokens": {
    "PasswordResetTokenLifespanMinutes": 120,
    "EmailConfirmationTokenLifespanMinutes": 1440
  },
  "Mfa": {
    "AuthenticatorIssuer": "AccountingSystem",
    "LoginChallengeLifespanMinutes": 5,
    "EmailOtpExpirationMinutes": 5,
    "EmailOtpMaxVerificationAttempts": 3,
    "EmailOtpResendCooldownSeconds": 60
  },
  "AuthSecurity": {
    "Lockout": {
      "MaxFailedAccessAttempts": 5,
      "LockoutMinutes": 5
    },
    "LoginCaptcha": {
      "FailedAttemptThreshold": 3
    },
    "RateLimiting": {
      "Login": {
        "PermitLimit": 5,
        "WindowSeconds": 60
      },
      "RegisterCompany": {
        "PermitLimit": 3,
        "WindowSeconds": 600
      },
      "ChangePassword": {
        "PermitLimit": 5,
        "WindowSeconds": 600
      },
      "ForgotPassword": {
        "PermitLimit": 3,
        "WindowSeconds": 900
      },
      "ResetPassword": {
        "PermitLimit": 5,
        "WindowSeconds": 900
      },
      "ConfirmEmail": {
        "PermitLimit": 5,
        "WindowSeconds": 900
      },
      "ResendConfirmation": {
        "PermitLimit": 3,
        "WindowSeconds": 900
      },
      "LoginMfa": {
        "PermitLimit": 5,
        "WindowSeconds": 300
      },
      "MfaManage": {
        "PermitLimit": 10,
        "WindowSeconds": 600
      }
    }
  },
  "Smtp": {
    "Host": "__SET_VIA_ENV__",
    "Port": "__SET_VIA_ENV__",
    "Username": "__SET_VIA_ENV__",
    "Password": "__SET_VIA_ENV__",
    "FromAddress": "__SET_VIA_ENV__",
    "FromName": "__SET_VIA_ENV__",
    "EnableSsl": "__SET_VIA_ENV__"
  },
  "AppUrls": {
    "ClientBaseUrl": "__SET_VIA_ENV__"
  },
  "BootstrapAdmin": {
    "Email": "__SET_VIA_ENV__",
    "FullName": "__SET_VIA_ENV__",
    "InitialPassword": "__SET_VIA_ENV__"
  },
  "PayMongo": {
    "SecretKey": "__SET_VIA_ENV__",
    "PublicKey": "__SET_VIA_ENV__",
    "WebhookSecret": "__SET_VIA_ENV__"
  },
  "Recaptcha": {
    "SecretKey": "__SET_VIA_ENV__",
    "ScoreThreshold": 0.5
  }
}
