# =============================================================================
# AccountingSystem Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your local development values.
# The .env file is gitignored and should NEVER be committed.
#
# KEY FORMAT:
# - Use double underscore (__) for nested configuration keys
# - Example: JwtSettings:Secret becomes JwtSettings__Secret
#
# IMPORTANT - BACKSLASH HANDLING:
# - .env files are NOT JSON - do NOT escape backslashes
# - Use SINGLE backslash for SQL Server instance names
# - CORRECT: Server=HOST\INSTANCE
# - WRONG:   Server=HOST\\INSTANCE (will be read literally as double backslash)
# =============================================================================

# -----------------------------------------------------------------------------
# Database Connection
# -----------------------------------------------------------------------------
# Use SINGLE backslash for SQL Server named instances (e.g., LAPTOP\SQLEXPRESS)
ConnectionStrings__DefaultConnection=

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
JwtSettings__Secret=

# -----------------------------------------------------------------------------
# Non-secret MFA Tuning (optional; appsettings.json has demo-safe defaults)
# -----------------------------------------------------------------------------
# Mfa__EmailOtpExpirationMinutes=5
# Mfa__EmailOtpMaxVerificationAttempts=3
# Mfa__EmailOtpResendCooldownSeconds=60

# -----------------------------------------------------------------------------
# SMTP Email Settings
# -----------------------------------------------------------------------------
Smtp__Host=
Smtp__Port=
Smtp__Username=
Smtp__Password=
Smtp__FromAddress=
Smtp__FromName=
Smtp__EnableSsl=

# -----------------------------------------------------------------------------
# Application URLs
# -----------------------------------------------------------------------------
AppUrls__ClientBaseUrl=

# -----------------------------------------------------------------------------
# Bootstrap Admin Account
# -----------------------------------------------------------------------------
BootstrapAdmin__Email=
BootstrapAdmin__FullName=
BootstrapAdmin__InitialPassword=

# -----------------------------------------------------------------------------
# PayMongo Payment Gateway (required in production)
# -----------------------------------------------------------------------------
PayMongo__SecretKey=
PayMongo__PublicKey=
PayMongo__WebhookSecret=

# -----------------------------------------------------------------------------
# Google reCAPTCHA (required in production)
# -----------------------------------------------------------------------------
Recaptcha__SiteKey=
Recaptcha__SecretKey=
